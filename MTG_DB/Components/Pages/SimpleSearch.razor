@page "/simplesearch"
@using MtgInventoryApp.Models
@using MtgInventoryApp.Services
@inject MtgInventoryApp.Services.ScryfallService Scryfall
@inject ToastService ToastService
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>MTGHUB - Search</PageTitle>

<div class="search-page">
    <!-- Header -->
    <header class="search-header">
        <div class="header-content">
            <a class="logo" href="/" title="Back to home">
                <span class="logo-icon">⬡</span>
                <span class="logo-text">MTGHUB</span>
            </a>
            <div class="search-box">
                <input class="search-input"
                       @bind="query"
                       @bind:event="oninput"
                       placeholder="Search for any Magic card..."
                       @onkeypress="HandleKeyPress" />
                <button class="search-btn" @onclick="DoSearch" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <svg class="search-btn-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <circle cx="12" cy="12" r="9" stroke-opacity="0.3"/>
                            <path d="M12 3a9 9 0 0 1 9 9" stroke-linecap="round"/>
                        </svg>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8"/>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        </svg>
                    }
                </button>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="search-main">
        @if (isLoading)
        {
            <div class="cards-grid">
                @for (int i = 0; i < 12; i++)
                {
                    <div class="card-item skeleton-card">
                        <div class="card-image-container skeleton-image-wrap">
                            <div class="skeleton-image"></div>
                        </div>
                        <div class="card-info">
                            <div class="skeleton-line skeleton-line-lg"></div>
                            <div class="skeleton-line skeleton-line-md"></div>
                            <div class="skeleton-line skeleton-line-sm"></div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-state">
                <div class="error-icon">⚠️</div>
                <h3>Search Failed</h3>
                <p>@errorMessage</p>
                <button class="action-btn" @onclick="DoSearch">Retry</button>
            </div>
        }
        else if (allCards.Count > 0)
        {
            <div class="results-header">
                <div class="results-header-left">
                    <h2>@totalCards cards found</h2>
                    <small>Page @currentPage of @TotalPages &nbsp;·&nbsp; Hover over 🔄 cards to see both sides</small>
                </div>
                <div class="view-toggle-group">
                    <button class="view-toggle-btn @(viewMode == "grid" ? "active" : "")" @onclick='() => SetViewMode("grid")' title="Grid view">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                            <rect x="0" y="0" width="6" height="6" rx="1"/>
                            <rect x="10" y="0" width="6" height="6" rx="1"/>
                            <rect x="0" y="10" width="6" height="6" rx="1"/>
                            <rect x="10" y="10" width="6" height="6" rx="1"/>
                        </svg>
                        Grid
                    </button>
                    <button class="view-toggle-btn @(viewMode == "list" ? "active" : "")" @onclick='() => SetViewMode("list")' title="List view">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                            <rect x="0" y="1" width="16" height="2" rx="1"/>
                            <rect x="0" y="7" width="16" height="2" rx="1"/>
                            <rect x="0" y="13" width="16" height="2" rx="1"/>
                        </svg>
                        List
                    </button>
                </div>
            </div>

            @if (viewMode == "grid")
            {
                <div class="cards-grid">
                    @foreach (var card in PagedCards)
                    {
                        <div class="card-item @GetRarityClass(card.Rarity)" @onclick="() => ShowCardDetails(card)">
                            <div class="card-image-container @(IsDoubleFacedCard(card) ? "dfc-container" : "")">
                                @if (IsDoubleFacedCard(card))
                                {
                                    <div class="dfc-indicator">🔄</div>
                                    @if (card.CardFaces.Count > 0 && !string.IsNullOrEmpty(card.CardFaces[0].ImageUris?.Normal))
                                    {
                                        <img src="@card.CardFaces[0].ImageUris.Normal" class="card-image dfc-front" alt="@card.CardFaces[0].Name" />
                                    }
                                    @if (card.CardFaces.Count > 1 && !string.IsNullOrEmpty(card.CardFaces[1].ImageUris?.Normal))
                                    {
                                        <img src="@card.CardFaces[1].ImageUris.Normal" class="card-image dfc-back" alt="@card.CardFaces[1].Name" />
                                    }
                                }
                                else if (!string.IsNullOrEmpty(GetCardImage(card)))
                                {
                                    <img src="@GetCardImage(card)" class="card-image" alt="@card.Name" />
                                }
                                else
                                {
                                    <div class="no-image">
                                        <span>🃏</span>
                                        <p>No image</p>
                                    </div>
                                }
                            </div>

                            <div class="card-info">
                                <h3 class="card-name">
                                    @card.Name
                                    @if (IsDoubleFacedCard(card))
                                    {
                                        <span class="dfc-badge">🔄</span>
                                    }
                                </h3>
                                <div class="card-details">
                                    <span class="card-set">@card.SetName</span>
                                    <span class="card-rarity">@GetRarityDisplay(card.Rarity)</span>
                                </div>
                                <div class="card-price">@FormatUsd(card.Prices?.Usd)</div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="cards-list">
                    <table class="list-table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Set</th>
                                <th>Type</th>
                                <th>Rarity</th>
                                <th>Price</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var card in PagedCards)
                            {
                                <tr class="list-row @GetRarityClass(card.Rarity)" @onclick="() => ShowCardDetails(card)">
                                    <td class="list-name">
                                        @card.Name
                                        @if (IsDoubleFacedCard(card)) { <span class="dfc-badge">🔄</span> }
                                    </td>
                                    <td class="list-set">@card.SetName</td>
                                    <td class="list-type">@(card.TypeLine ?? "—")</td>
                                    <td class="list-rarity"><span class="rarity-pill rarity-pill-@card.Rarity?.ToLower()">@GetRarityDisplay(card.Rarity)</span></td>
                                    <td class="list-price">@FormatUsd(card.Prices?.Usd)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <div class="pagination">
                <button class="page-btn" @onclick="PrevPage" disabled="@(!CanGoPrev)">← Previous</button>
                <span class="page-info">Page @currentPage of @TotalPages</span>
                <button class="page-btn" @onclick="NextPage" disabled="@(!CanGoNext || isLoadingMore)">
                    @if (isLoadingMore) { <span>Loading...</span> } else { <span>Next →</span> }
                </button>
            </div>
        }
        else if (hasSearched)
        {
            <div class="empty-state">
                <div class="empty-icon">🔍</div>
                <h3>No cards found</h3>
                <p>Try different search terms</p>
                <button class="action-btn" @onclick="ResetSearch">Try Again</button>
            </div>
        }
        else
        {
            <div class="welcome-state">
                <div class="welcome-icon">✨</div>
                <h3>Search for Magic cards</h3>
                <p>Enter a card name above to start searching</p>
            </div>
        }
    </main>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? Query { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public int Page { get; set; } = 1;

    private string query = "";
    private List<ScryfallCard> allCards = new();
    private bool isLoading;
    private bool isLoadingMore;
    private bool hasSearched;
    private string? errorMessage;
    private string viewMode = "grid";
    private bool viewModeLoaded;

    // Pagination state
    private int currentPage = 1;
    private const int pageSize = 20;
    private bool hasMore;
    private int totalCards;
    private int scryfallPage = 1;

    private IEnumerable<ScryfallCard> PagedCards => allCards.Skip((currentPage - 1) * pageSize).Take(pageSize);
    private int TotalPages => totalCards > 0
        ? (int)Math.Ceiling(totalCards / (double)pageSize)
        : (int)Math.Ceiling(allCards.Count / (double)pageSize);
    private bool CanGoPrev => currentPage > 1;
    private bool CanGoNext => currentPage < TotalPages || hasMore;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !viewModeLoaded)
        {
            viewModeLoaded = true;
            var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "mtghub_view");
            if (saved == "list" || saved == "grid")
            {
                viewMode = saved;
                StateHasChanged();
            }
        }
    }

    private async Task SetViewMode(string mode)
    {
        viewMode = mode;
        await JS.InvokeVoidAsync("localStorage.setItem", "mtghub_view", mode);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(Query) && Query != query)
        {
            query = Query;
            await DoSearch();
            // Restore page after search loads data
            if (Page > 1)
            {
                while (currentPage < Page)
                {
                    await NextPage();
                }
            }
        }
    }

    private async Task DoSearch()
    {
        if (string.IsNullOrWhiteSpace(query)) return;

        hasSearched = true;
        isLoading = true;
        errorMessage = null;
        allCards = new();
        currentPage = 1;
        scryfallPage = 1;
        totalCards = 0;
        hasMore = false;

        try
        {
            var result = await Scryfall.SearchAsync(query, scryfallPage);
            allCards.AddRange(result.Data);
            hasMore = result.HasMore;
            totalCards = result.TotalCards;
        }
        catch (HttpRequestException)
        {
            errorMessage = "Network error — check your connection and try again.";
            ToastService.Show(errorMessage);
        }
        catch (Exception ex)
        {
            errorMessage = $"Search failed: {ex.Message}";
            ToastService.Show(errorMessage);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task NextPage()
    {
        var targetPage = currentPage + 1;
        while (targetPage * pageSize > allCards.Count && hasMore)
        {
            isLoadingMore = true;
            StateHasChanged();
            scryfallPage++;
            try
            {
                var result = await Scryfall.SearchAsync(query, scryfallPage);
                allCards.AddRange(result.Data);
                hasMore = result.HasMore;
            }
            catch (HttpRequestException)
            {
                ToastService.Show("Network error while loading more cards.", ToastLevel.Warning);
                hasMore = false;
                break;
            }
            catch
            {
                hasMore = false;
                break;
            }
            finally
            {
                isLoadingMore = false;
            }
        }
        currentPage = targetPage;
        StateHasChanged();
    }

    private void PrevPage()
    {
        if (CanGoPrev) currentPage--;
    }

    private void HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") DoSearch();
    }

    private void ResetSearch()
    {
        query = "";
        hasSearched = false;
        errorMessage = null;
        allCards = new();
        currentPage = 1;
        totalCards = 0;
        hasMore = false;
    }

    private void ShowCardDetails(ScryfallCard card)
    {
        var returnUrl = Uri.EscapeDataString(query);
        Navigation.NavigateTo($"/card/{card.Id}?returnQuery={returnUrl}&returnPage={currentPage}");
    }

    private bool IsDoubleFacedCard(ScryfallCard card)
    {
        return card.Layout == "transform" || card.Layout == "modal_dfc" || card.CardFaces?.Count > 1;
    }

    private string GetCardImage(ScryfallCard card)
    {
        if (IsDoubleFacedCard(card) && card.CardFaces.Count > 0)
            return card.CardFaces[0].ImageUris?.Normal ?? "";
        return card.ImageUris?.Normal ?? "";
    }

    private static string FormatUsd(string? usd) => string.IsNullOrWhiteSpace(usd) ? "Price N/A" : $"${usd}";

    private string GetRarityClass(string? rarity) => rarity?.ToLower() switch
    {
        "common" => "rarity-common",
        "uncommon" => "rarity-uncommon",
        "rare" => "rarity-rare",
        "mythic" => "rarity-mythic",
        _ => "rarity-common"
    };

    private string GetRarityDisplay(string? rarity) => rarity?.ToLower() switch
    {
        "common" => "Common",
        "uncommon" => "Uncommon",
        "rare" => "Rare",
        "mythic" => "Mythic",
        _ => rarity ?? "Unknown"
    };
}
