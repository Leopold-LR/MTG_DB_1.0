@page "/simplesearch"
@using MtgInventoryApp.Models
@inject MtgInventoryApp.Services.ScryfallService Scryfall
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>MTGHUB - Search</PageTitle>

<div class="search-page">
    <!-- Header -->
    <header class="search-header">
        <div class="header-content">
            <h1 class="logo" @onclick='() => Navigation.NavigateTo("/")'>MTGHUB</h1>
            <div class="search-box">
                <input class="search-input"
                       @bind="query"
                       @bind:event="oninput"
                       placeholder="Search for any Magic card..."
                       @onkeypress="HandleKeyPress" />
                <button class="search-btn" @onclick="DoSearch" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span>Searching...</span>
                    }
                    else
                    {
                        <span>🔍</span>
                    }
                </button>
            </div>
            <button class="home-btn" @onclick='() => Navigation.NavigateTo("/")'>Home</button>
        </div>
    </header>

    <!-- Main Content -->
    <main class="search-main">
        @if (isLoading)
        {
            <div class="loading">
                <div class="spinner"></div>
                <p>Searching cards...</p>
            </div>
        }
        else if (cards?.Length > 0)
        {
            <div class="results-header">
                <h2>Found @cards.Length cards</h2>
                <small>Hover over 🔄 cards to see both sides</small>
            </div>

            <div class="cards-grid">
                @foreach (var card in cards)
                {
                    <div class="card-item @GetRarityClass(card.Rarity)" @onclick="() => ShowCardDetails(card)">
                        <div class="card-image-container @(IsDoubleFacedCard(card) ? "dfc-container" : "")">
                            @if (IsDoubleFacedCard(card))
                            {
                                <div class="dfc-indicator">🔄</div>
                                @if (card.CardFaces.Count > 0 && !string.IsNullOrEmpty(card.CardFaces[0].ImageUris?.Normal))
                                {
                                    <img src="@card.CardFaces[0].ImageUris.Normal" class="card-image dfc-front" alt="@card.CardFaces[0].Name" />
                                }
                                @if (card.CardFaces.Count > 1 && !string.IsNullOrEmpty(card.CardFaces[1].ImageUris?.Normal))
                                {
                                    <img src="@card.CardFaces[1].ImageUris.Normal" class="card-image dfc-back" alt="@card.CardFaces[1].Name" />
                                }
                            }
                            else if (!string.IsNullOrEmpty(GetCardImage(card)))
                            {
                                <img src="@GetCardImage(card)" class="card-image" alt="@card.Name" />
                            }
                            else
                            {
                                <div class="no-image">
                                    <span>🃏</span>
                                    <p>No image</p>
                                </div>
                            }
                        </div>

                        <div class="card-info">
                            <h3 class="card-name">
                                @card.Name
                                @if (IsDoubleFacedCard(card))
                                {
                                    <span class="dfc-badge">🔄</span>
                                }
                            </h3>
                            <div class="card-details">
                                <span class="card-set">@card.SetName</span>
                                <span class="card-rarity">@GetRarityDisplay(card.Rarity)</span>
                            </div>
                            <div class="card-price">@FormatUsd(card.Prices?.Usd)</div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (hasSearched)
        {
            <div class="empty-state">
                <div class="empty-icon">🔍</div>
                <h3>No cards found</h3>
                <p>Try different search terms</p>
                <button class="action-btn" @onclick="ResetSearch">Try Again</button>
            </div>
        }
        else
        {
            <div class="welcome-state">
                <div class="welcome-icon">✨</div>
                <h3>Search for Magic cards</h3>
                <p>Enter a card name above to start searching</p>
            </div>
        }
    </main>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? Query { get; set; }

    private string query = "";
    private ScryfallCard[] cards = Array.Empty<ScryfallCard>();
    private bool isLoading;
    private bool hasSearched;
    private string? errorMessage;

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(Query))
        {
            query = Query;
            _ = DoSearch();
        }
    }

    private async Task DoSearch()
    {
        if (string.IsNullOrWhiteSpace(query)) return;

        hasSearched = true;
        isLoading = true;
        errorMessage = null;
        cards = Array.Empty<ScryfallCard>();

        try
        {
            cards = await Scryfall.SearchAsync(query);
        }
        catch (Exception ex)
        {
            errorMessage = $"Search failed: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") DoSearch();
    }

    private void ResetSearch()
    {
        query = "";
        hasSearched = false;
        cards = Array.Empty<ScryfallCard>();
    }

    private void ShowCardDetails(ScryfallCard card)
    {
        Navigation.NavigateTo($"/card/{card.Id}");
    }

    private bool IsDoubleFacedCard(ScryfallCard card)
    {
        return card.Layout == "transform" || card.Layout == "modal_dfc" || card.CardFaces?.Count > 1;
    }

    private string GetCardImage(ScryfallCard card)
    {
        if (IsDoubleFacedCard(card) && card.CardFaces.Count > 0)
            return card.CardFaces[0].ImageUris?.Normal ?? "";
        return card.ImageUris?.Normal ?? "";
    }

    private static string FormatUsd(string? usd) => string.IsNullOrWhiteSpace(usd) ? "Price N/A" : $"${usd}";

    private string GetRarityClass(string? rarity) => rarity?.ToLower() switch
    {
        "common" => "rarity-common",
        "uncommon" => "rarity-uncommon",
        "rare" => "rarity-rare",
        "mythic" => "rarity-mythic",
        _ => "rarity-common"
    };

    private string GetRarityDisplay(string? rarity) => rarity?.ToLower() switch
    {
        "common" => "Common",
        "uncommon" => "Uncommon",
        "rare" => "Rare",
        "mythic" => "Mythic",
        _ => rarity ?? "Unknown"
    };
}