@page "/simplesearch"
@using MtgInventoryApp.Models
@inject MtgInventoryApp.Services.ScryfallService Scryfall
@inject NavigationManager Navigation

<PageTitle>MTG Search</PageTitle>

<div class="gradient-background"></div>
<div class="grid-overlay"></div>

<div class="simplesearch-page">
    <div class="container pt-4 pt-md-5">
        <div class="row align-items-center mb-4 mb-md-5">
            <div class="col-md-4 mb-3 mb-md-0">
                <h1 class="h3 mb-0 title-glow" style="cursor: pointer;" @onclick='() => Navigation.NavigateTo("/")'>
                    MTG SEARCH
                </h1>
            </div>

            <div class="col-md-5 mb-3 mb-md-0">
                <div class="input-group">
                    <input type="text"
                           class="form-control form-control-dark py-2 px-3"
                           @bind="query"
                           @bind:event="oninput"
                           placeholder="Search for Magic cards..."
                           @onkeypress="HandleKeyPress" />
                </div>
            </div>

            <div class="col-md-3">
                <div class="d-flex gap-3 justify-content-md-end">
                    <button class="btn btn-search flex-grow-1" @onclick="DoSearch" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2" style="color: white;"></span>
                            <span>Searching</span>
                        }
                        else
                        {
                            <span>Search</span>
                        }
                    </button>
                    <button class="btn btn-home" @onclick='() => Navigation.NavigateTo("/")'>
                        Home
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="container">
        @if (isLoading)
        {
            <div class="text-center py-5 my-5">
                <div class="spinner-border text-info mb-3" style="width: 3rem; height: 3rem;"></div>
                <p class="text-light">Searching cards...</p>
            </div>
        }
        else if (cards?.Length > 0)
        {
            <div class="mb-4">
                <div class="d-flex align-items-center gap-3 mb-2">
                    <h2 class="h5 text-light fw-normal mb-0">
                        Showing <span class="results-count">@cards.Length</span> cards
                    </h2>
                    @if (HasDoubleFacedCards())
                    {
                        <span class="badge badge-set">Hover for alt faces</span>
                    }
                </div>
            </div>

            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
                @foreach (var card in cards)
                {
                    <div class="col">
                        <div class="card card-mtg h-100" style="cursor: pointer;" @onclick="() => ShowCardDetails(card)">
                            <div class="card-img-container">
                                @if (IsDoubleFacedCard(card))
                                {
                                    @if (card.CardFaces?.Count > 0 && !string.IsNullOrEmpty(card.CardFaces[0].ImageUris?.Large))
                                    {
                                        <img src="@card.CardFaces[0].ImageUris.Large"
                                             class="card-img card-face-front"
                                             alt="@card.CardFaces[0].Name" />
                                    }
                                    @if (card.CardFaces?.Count > 1 && !string.IsNullOrEmpty(card.CardFaces[1].ImageUris?.Large))
                                    {
                                        <img src="@card.CardFaces[1].ImageUris.Large"
                                             class="card-img card-face-back"
                                             alt="@card.CardFaces[1].Name" />
                                    }
                                    @if (card.CardFaces == null || card.CardFaces.Count == 0 || string.IsNullOrEmpty(card.CardFaces[0]?.ImageUris?.Large))
                                    {
                                        <div class="no-image-placeholder w-100 h-100 d-flex align-items-center justify-content-center">
                                            <span class="text-muted">No image</span>
                                        </div>
                                    }
                                }
                                else if (!string.IsNullOrEmpty(GetCardImage(card)))
                                {
                                    <img src="@GetCardImage(card)" class="card-img" alt="@card.Name" />
                                }
                                else
                                {
                                    <div class="no-image-placeholder w-100 h-100 d-flex align-items-center justify-content-center">
                                        <span class="text-muted">No image</span>
                                    </div>
                                }
                            </div>

                            <div class="card-body p-3">
                                <h6 class="card-title mb-2 text-light fw-semibold" style="min-height: 48px;">
                                    @card.Name
                                </h6>

                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="badge badge-set rounded-pill">@card.SetName</span>
                                    <span class="badge badge-rarity rounded-pill">
                                        @GetRarityDisplay(card.Rarity)
                                    </span>
                                </div>

                                <div class="text-end">
                                    <span class="price-display">
                                        @FormatUsd(card.Prices?.Usd)
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (hasSearched)
        {
            <div class="text-center py-5 my-5 empty-state p-5">
                <h3 class="h4 electric-text mb-3">No cards found</h3>
                <p class="text-light mb-4">Try different search terms</p>
                <button class="btn btn-search px-4 py-2" @onclick="ResetSearch">
                    Clear Search
                </button>
            </div>
        }
        else
        {
            <div class="text-center py-5 my-5">
                <h3 class="h4 electric-text mb-3">Search Magic Cards</h3>
                <p class="text-light">Enter a card name, set, or type to begin</p>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? Query { get; set; }

    private string query = "";
    private ScryfallCard[] cards = Array.Empty<ScryfallCard>();
    private bool isLoading;
    private bool hasSearched;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(Query))
        {
            query = Query;
            await DoSearch();
        }
    }

    private async Task DoSearch()
    {
        if (string.IsNullOrWhiteSpace(query)) return;

        hasSearched = true;
        isLoading = true;
        errorMessage = null;
        cards = Array.Empty<ScryfallCard>();

        try
        {
            cards = await Scryfall.SearchAsync(query);
        }
        catch (Exception ex)
        {
            errorMessage = $"Search failed: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _ = DoSearch();
        }
    }

    private void ResetSearch()
    {
        query = "";
        hasSearched = false;
        cards = Array.Empty<ScryfallCard>();
        Navigation.NavigateTo("/simplesearch", forceLoad: false);
    }

    private void ShowCardDetails(ScryfallCard card)
    {
        Navigation.NavigateTo($"/card/{card.Id}");
    }

    private bool IsDoubleFacedCard(ScryfallCard card)
    {
        return card.Layout == "transform" || card.Layout == "modal_dfc" || (card.CardFaces?.Count > 1);
    }

    private bool HasDoubleFacedCards()
    {
        return cards.Any(c => IsDoubleFacedCard(c));
    }

    private string GetCardImage(ScryfallCard card)
    {
        if (IsDoubleFacedCard(card) && card.CardFaces?.Count > 0)
            return card.CardFaces[0].ImageUris?.Large ?? "";
        return card.ImageUris?.Large ?? "";
    }

    private static string FormatUsd(string? usd)
    {
        if (string.IsNullOrWhiteSpace(usd))
            return "—";
        if (decimal.TryParse(usd, out var price))
            return $"${price:F2}";
        return "$0.00";
    }

    private string GetRarityDisplay(string? rarity) => rarity?.ToLower() switch
    {
        "common" => "Common",
        "uncommon" => "Uncommon",
        "rare" => "Rare",
        "mythic" => "Mythic",
        _ => rarity ?? "Unknown"
    };
}