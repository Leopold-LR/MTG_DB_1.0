@page "/simplesearch"
@using MtgInventoryApp.Models
@inject MtgInventoryApp.Services.ScryfallService Scryfall
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>MTGHUB - Search</PageTitle>

<div class="search-page">
    <!-- Header -->
    <header class="search-header">
        <div class="header-content">
            <h1 class="logo" @onclick='() => Navigation.NavigateTo("/")'>MTGHUB</h1>
            <div class="search-box">
                <input class="search-input"
                       @bind="query"
                       @bind:event="oninput"
                       placeholder="Search for any Magic card..."
                       @onkeypress="HandleKeyPress" />
                <button class="search-btn" @onclick="DoSearch" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span>Searching...</span>
                    }
                    else
                    {
                        <span>🔍</span>
                    }
                </button>
            </div>
            <button class="filter-toggle-btn @(showFilters ? "active" : "")" @onclick="ToggleFilters">
                Filters @(HasActiveFilters ? "●" : "")
            </button>
            <button class="home-btn" @onclick='() => Navigation.NavigateTo("/")'>Home</button>
        </div>
    </header>

    <!-- Filter Panel -->
    @if (showFilters)
    {
        <div class="filter-panel">
            <div class="filter-panel-inner">

                <!-- Colors -->
                <div class="filter-group">
                    <label class="filter-label">Colors</label>
                    <div class="color-chips">
                        @foreach (var c in colorOptions)
                        {
                            <button class="color-chip color-@c.Key @(selectedColors.Contains(c.Key) ? "selected" : "")"
                                    @onclick="() => ToggleColor(c.Key)"
                                    title="@c.Value">
                                @c.Key
                            </button>
                        }
                    </div>
                </div>

                <!-- Type -->
                <div class="filter-group">
                    <label class="filter-label">Type</label>
                    <select class="filter-select" @bind="selectedType">
                        <option value="">Any</option>
                        @foreach (var t in typeOptions)
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                </div>

                <!-- Set -->
                <div class="filter-group">
                    <label class="filter-label">Set</label>
                    @if (isLoadingSets)
                    {
                        <span class="filter-loading">Loading sets…</span>
                    }
                    else
                    {
                        <select class="filter-select filter-select-wide" @bind="selectedSet">
                            <option value="">Any</option>
                            @foreach (var s in availableSets)
                            {
                                <option value="@s.Code">@s.Name</option>
                            }
                        </select>
                    }
                </div>

                <!-- Rarity -->
                <div class="filter-group">
                    <label class="filter-label">Rarity</label>
                    <div class="rarity-options">
                        @foreach (var r in rarityOptions)
                        {
                            <label class="rarity-radio">
                                <input type="radio" name="rarity" value="@r.Key"
                                       checked="@(selectedRarity == r.Key)"
                                       @onchange="() => selectedRarity = r.Key" />
                                <span class="rarity-label rarity-dot-@r.Key">@r.Value</span>
                            </label>
                        }
                    </div>
                </div>

                <!-- CMC -->
                <div class="filter-group">
                    <label class="filter-label">CMC</label>
                    <div class="cmc-range">
                        <input type="number" class="cmc-input" min="0" max="20"
                               placeholder="Min"
                               @bind="cmcMin" @bind:event="oninput" />
                        <span class="cmc-dash">–</span>
                        <input type="number" class="cmc-input" min="0" max="20"
                               placeholder="Max"
                               @bind="cmcMax" @bind:event="oninput" />
                    </div>
                </div>

                <!-- Actions -->
                <div class="filter-actions">
                    <button class="filter-apply-btn" @onclick="DoSearch" disabled="@isLoading">
                        Apply
                    </button>
                    <button class="filter-clear-btn" @onclick="ClearFilters">
                        Clear
                    </button>
                </div>

            </div>
        </div>
    }

    <!-- Main Content -->
    <main class="search-main">
        @if (isLoading)
        {
            <div class="loading">
                <div class="spinner"></div>
                <p>Searching cards...</p>
            </div>
        }
        else if (allCards.Count > 0)
        {
            <div class="results-header">
                <h2>@totalCards cards found</h2>
                <small>Page @currentPage of @TotalPages &nbsp;·&nbsp; Hover over 🔄 cards to see both sides</small>
            </div>

            <div class="cards-grid">
                @foreach (var card in PagedCards)
                {
                    <div class="card-item @GetRarityClass(card.Rarity)" @onclick="() => ShowCardDetails(card)">
                        <div class="card-image-container @(IsDoubleFacedCard(card) ? "dfc-container" : "")">
                            @if (IsDoubleFacedCard(card))
                            {
                                <div class="dfc-indicator">🔄</div>
                                @if (card.CardFaces.Count > 0 && !string.IsNullOrEmpty(card.CardFaces[0].ImageUris?.Normal))
                                {
                                    <img src="@card.CardFaces[0].ImageUris.Normal" class="card-image dfc-front" alt="@card.CardFaces[0].Name" />
                                }
                                @if (card.CardFaces.Count > 1 && !string.IsNullOrEmpty(card.CardFaces[1].ImageUris?.Normal))
                                {
                                    <img src="@card.CardFaces[1].ImageUris.Normal" class="card-image dfc-back" alt="@card.CardFaces[1].Name" />
                                }
                            }
                            else if (!string.IsNullOrEmpty(GetCardImage(card)))
                            {
                                <img src="@GetCardImage(card)" class="card-image" alt="@card.Name" />
                            }
                            else
                            {
                                <div class="no-image">
                                    <span>🃏</span>
                                    <p>No image</p>
                                </div>
                            }
                        </div>

                        <div class="card-info">
                            <h3 class="card-name">
                                @card.Name
                                @if (IsDoubleFacedCard(card))
                                {
                                    <span class="dfc-badge">🔄</span>
                                }
                            </h3>
                            <div class="card-details">
                                <span class="card-set">@card.SetName</span>
                                <span class="card-rarity">@GetRarityDisplay(card.Rarity)</span>
                            </div>
                            <div class="card-price">@FormatUsd(card.Prices?.Usd)</div>
                        </div>
                    </div>
                }
            </div>

            <div class="pagination">
                <button class="page-btn" @onclick="PrevPage" disabled="@(!CanGoPrev)">← Previous</button>
                <span class="page-info">Page @currentPage of @TotalPages</span>
                <button class="page-btn" @onclick="NextPage" disabled="@(!CanGoNext || isLoadingMore)">
                    @if (isLoadingMore) { <span>Loading...</span> } else { <span>Next →</span> }
                </button>
            </div>
        }
        else if (hasSearched)
        {
            <div class="empty-state">
                <div class="empty-icon">🔍</div>
                <h3>No cards found</h3>
                <p>Try different search terms or adjust your filters</p>
                <button class="action-btn" @onclick="ResetSearch">Try Again</button>
            </div>
        }
        else
        {
            <div class="welcome-state">
                <div class="welcome-icon">✨</div>
                <h3>Search for Magic cards</h3>
                <p>Enter a card name above or use the Filters button to browse</p>
            </div>
        }
    </main>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? Query { get; set; }

    private string query = "";
    private List<ScryfallCard> allCards = new();
    private bool isLoading;
    private bool isLoadingMore;
    private bool hasSearched;
    private string? errorMessage;

    // Pagination
    private int currentPage = 1;
    private const int pageSize = 20;
    private bool hasMore;
    private int totalCards;
    private int scryfallPage = 1;

    private IEnumerable<ScryfallCard> PagedCards => allCards.Skip((currentPage - 1) * pageSize).Take(pageSize);
    private int TotalPages => totalCards > 0
        ? (int)Math.Ceiling(totalCards / (double)pageSize)
        : (int)Math.Ceiling(allCards.Count / (double)pageSize);
    private bool CanGoPrev => currentPage > 1;
    private bool CanGoNext => currentPage < TotalPages || hasMore;

    // Filter state
    private bool showFilters;
    private bool isLoadingSets;
    private List<ScryfallSet> availableSets = new();
    private HashSet<string> selectedColors = new();
    private string selectedType = "";
    private string selectedSet = "";
    private string selectedRarity = "";
    private int? cmcMin;
    private int? cmcMax;

    private bool HasActiveFilters =>
        selectedColors.Count > 0 || !string.IsNullOrEmpty(selectedType) ||
        !string.IsNullOrEmpty(selectedSet) || !string.IsNullOrEmpty(selectedRarity) ||
        cmcMin.HasValue || cmcMax.HasValue;

    private static readonly Dictionary<string, string> colorOptions = new()
    {
        ["W"] = "White",
        ["U"] = "Blue",
        ["B"] = "Black",
        ["R"] = "Red",
        ["G"] = "Green",
        ["C"] = "Colorless"
    };

    private static readonly string[] typeOptions =
    [
        "Creature", "Instant", "Sorcery", "Enchantment",
        "Artifact", "Planeswalker", "Land", "Battle"
    ];

    private static readonly Dictionary<string, string> rarityOptions = new()
    {
        [""] = "Any",
        ["common"] = "Common",
        ["uncommon"] = "Uncommon",
        ["rare"] = "Rare",
        ["mythic"] = "Mythic"
    };

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(Query))
        {
            query = Query;
            _ = DoSearch();
        }
    }

    private async Task ToggleFilters()
    {
        showFilters = !showFilters;
        if (showFilters && availableSets.Count == 0)
        {
            isLoadingSets = true;
            availableSets = await Scryfall.GetSetsAsync();
            isLoadingSets = false;
        }
    }

    private void ToggleColor(string color)
    {
        if (!selectedColors.Remove(color))
            selectedColors.Add(color);
    }

    private void ClearFilters()
    {
        selectedColors.Clear();
        selectedType = "";
        selectedSet = "";
        selectedRarity = "";
        cmcMin = null;
        cmcMax = null;
    }

    private string BuildFilterQuery()
    {
        var parts = new List<string>();

        if (selectedColors.Count > 0)
        {
            // c:wubrgc — combined color filter
            var colorStr = string.Join("", selectedColors).ToLower();
            parts.Add($"c:{colorStr}");
        }

        if (!string.IsNullOrEmpty(selectedType))
            parts.Add($"t:{selectedType.ToLower()}");

        if (!string.IsNullOrEmpty(selectedSet))
            parts.Add($"e:{selectedSet}");

        if (!string.IsNullOrEmpty(selectedRarity))
            parts.Add($"r:{selectedRarity}");

        if (cmcMin.HasValue && cmcMax.HasValue && cmcMin == cmcMax)
            parts.Add($"cmc={cmcMin}");
        else
        {
            if (cmcMin.HasValue) parts.Add($"cmc>={cmcMin}");
            if (cmcMax.HasValue) parts.Add($"cmc<={cmcMax}");
        }

        return string.Join(" ", parts);
    }

    private async Task DoSearch()
    {
        var filterQuery = BuildFilterQuery();
        var fullQuery = string.Join(" ", new[] { query.Trim(), filterQuery }.Where(s => !string.IsNullOrEmpty(s)));

        if (string.IsNullOrWhiteSpace(fullQuery)) return;

        hasSearched = true;
        isLoading = true;
        errorMessage = null;
        allCards = new();
        currentPage = 1;
        scryfallPage = 1;
        totalCards = 0;
        hasMore = false;

        try
        {
            var result = await Scryfall.SearchAsync(fullQuery, scryfallPage);
            allCards.AddRange(result.Data);
            hasMore = result.HasMore;
            totalCards = result.TotalCards;
        }
        catch (Exception ex)
        {
            errorMessage = $"Search failed: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task NextPage()
    {
        var targetPage = currentPage + 1;
        while (targetPage * pageSize > allCards.Count && hasMore)
        {
            isLoadingMore = true;
            StateHasChanged();
            scryfallPage++;
            try
            {
                var filterQuery = BuildFilterQuery();
                var fullQuery = string.Join(" ", new[] { query.Trim(), filterQuery }.Where(s => !string.IsNullOrEmpty(s)));
                var result = await Scryfall.SearchAsync(fullQuery, scryfallPage);
                allCards.AddRange(result.Data);
                hasMore = result.HasMore;
            }
            catch
            {
                hasMore = false;
                break;
            }
            finally
            {
                isLoadingMore = false;
            }
        }
        currentPage = targetPage;
        StateHasChanged();
    }

    private void PrevPage()
    {
        if (CanGoPrev) currentPage--;
    }

    private void HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") _ = DoSearch();
    }

    private void ResetSearch()
    {
        query = "";
        hasSearched = false;
        allCards = new();
        currentPage = 1;
        totalCards = 0;
        hasMore = false;
        ClearFilters();
    }

    private void ShowCardDetails(ScryfallCard card)
    {
        Navigation.NavigateTo($"/card/{card.Id}");
    }

    private bool IsDoubleFacedCard(ScryfallCard card)
    {
        return card.Layout == "transform" || card.Layout == "modal_dfc" || card.CardFaces?.Count > 1;
    }

    private string GetCardImage(ScryfallCard card)
    {
        if (IsDoubleFacedCard(card) && card.CardFaces.Count > 0)
            return card.CardFaces[0].ImageUris?.Normal ?? "";
        return card.ImageUris?.Normal ?? "";
    }

    private static string FormatUsd(string? usd) => string.IsNullOrWhiteSpace(usd) ? "Price N/A" : $"${usd}";

    private string GetRarityClass(string? rarity) => rarity?.ToLower() switch
    {
        "common" => "rarity-common",
        "uncommon" => "rarity-uncommon",
        "rare" => "rarity-rare",
        "mythic" => "rarity-mythic",
        _ => "rarity-common"
    };

    private string GetRarityDisplay(string? rarity) => rarity?.ToLower() switch
    {
        "common" => "Common",
        "uncommon" => "Uncommon",
        "rare" => "Rare",
        "mythic" => "Mythic",
        _ => rarity ?? "Unknown"
    };
}
