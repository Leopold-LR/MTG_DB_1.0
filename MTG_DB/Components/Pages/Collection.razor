@page "/collection"
@rendermode InteractiveServer
@using MtgInventoryApp.Services
@inject ToastService ToastService
@inject NavigationManager Navigation

<PageTitle>MTGHUB - Collections</PageTitle>

<div class="collection-page">

    @if (selectedCollectionKey == null)
    {
        <!-- ══════════════════════════════════════════
             COLLECTIONS LIST VIEW
             ══════════════════════════════════════════ -->
        <header class="collection-header">
            <div class="col-header-inner">
                <a class="logo" href="/" title="Back to home">
                    <span class="logo-icon">⬡</span>
                    <span class="logo-text">MTGHUB</span>
                </a>
                <div class="col-header-title-block">
                    <h1 class="collection-title">My Collections</h1>
                    <p class="collection-subtitle">
                        @allCollections.Count collection@(allCollections.Count == 1 ? "" : "s")
                        &nbsp;·&nbsp;
                        @allCollections.Sum(g => g.Cards.Sum(c => c.Quantity)) cards total
                    </p>
                </div>
                <div class="col-header-actions">
                    <button class="new-collection-btn" @onclick="OpenCreateModal">
                        <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                            <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/>
                        </svg>
                        <span>New Collection</span>
                    </button>
                </div>
            </div>
        </header>

        <!-- ── Type Filter Tabs ────────────────────────────────────────────── -->
        <div class="type-filter-tabs">
            <div class="type-filter-inner">
                @foreach (var tab in new[] { "All", "Binder", "Deck", "Bulk" })
                {
                    var tabName  = tab;
                    var tabCount = tabName == "All"
                        ? allCollections.Count
                        : allCollections.Count(g => g.Type == tabName);
                    <button class="type-tab @(activeTypeFilter == tabName ? $"type-tab-active type-tab-active-{tabName.ToLower()}" : "")"
                            @onclick="() => activeTypeFilter = tabName">
                        @tabName
                        <span class="tab-count">@tabCount</span>
                    </button>
                }
            </div>
        </div>

        <!-- Collections Search & Filter Bar -->
        <div class="collections-filter-bar">
            <div class="collections-filter-inner">
                <div class="col-list-search-box">
                    <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                    <input class="col-list-search-input"
                           @bind="collectionSearch"
                           @bind:event="oninput"
                           placeholder="Search collections…" />
                    @if (!string.IsNullOrEmpty(collectionSearch))
                    {
                        <button class="clear-filter-btn" @onclick='() => collectionSearch = ""'>
                            <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14">
                                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
                            </svg>
                        </button>
                    }
                </div>
                <span class="col-list-count">
                    @FilteredCollections.Count() node@(FilteredCollections.Count() == 1 ? "" : "s")
                </span>
            </div>
        </div>

        <main class="collections-list-main">
            @if (!FilteredCollections.Any())
            {
                <div class="col-no-results">
                    <div class="col-no-results-icon">🔍</div>
                    <p>No collections match <strong>"@collectionSearch"</strong></p>
                    <button class="clear-search-btn" @onclick='() => collectionSearch = ""'>Clear search</button>
                </div>
            }
            else
            {
                <div class="collections-grid">
                    @foreach (var group in FilteredCollections)
                    {
                        var groupCards   = group.Cards;
                        var totalQty     = groupCards.Sum(c => c.Quantity);
                        var uniqueCount  = groupCards.Count;
                        var hasValue     = groupCards.Any(c => c.PriceUsd.HasValue);
                        var totalValue   = groupCards.Sum(c => (c.PriceUsd ?? 0m) * c.Quantity);
                        var foilCount    = groupCards.Count(c => c.IsFoil);
                        var maxQty       = allCollections.Max(g2 => g2.Cards.Sum(c => c.Quantity));
                        var fillPct      = maxQty > 0 ? (int)Math.Round((double)totalQty / maxQty * 100) : 0;

                        <div class="collection-tile @(pendingDeleteKey == group.Key ? "tile-confirm-delete" : "")">

                            @if (pendingDeleteKey == group.Key)
                            {
                                <div class="tile-delete-confirm">
                                    <p class="tile-delete-msg">Delete <strong>@group.Name</strong>?</p>
                                    <div class="tile-delete-actions">
                                        <button class="tile-delete-yes" @onclick="() => ConfirmDelete(group.Key)">Delete</button>
                                        <button class="tile-delete-no" @onclick="CancelDelete">Cancel</button>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <!-- Node pulse indicator -->
                                <div class="tile-node-dot"></div>

                                <!-- Type badge -->
                                <span class="type-badge type-badge-@group.Type.ToLower()">@group.Type</span>

                                <!-- Delete button (top-right) -->
                                <button class="tile-delete-btn" @onclick="() => RequestDelete(group.Key)" title="Delete collection">
                                    <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14">
                                        <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm4 0a1 1 0 012 0v6a1 1 0 11-2 0V8z" clip-rule="evenodd"/>
                                    </svg>
                                </button>

                                <!-- Main clickable area -->
                                <button class="tile-click-area" @onclick="() => OpenCollection(group.Key)">

                                    <!-- Icon slab -->
                                    <div class="tile-icon-wrap">
                                        <span class="tile-icon">@group.Icon</span>
                                    </div>

                                    <!-- Body -->
                                    <div class="tile-body">
                                        <h2 class="tile-name">@group.Name</h2>
                                        <div class="tile-stats-row">
                                            <span class="tile-stat">
                                                <span class="tile-stat-val">@totalQty</span>
                                                <span class="tile-stat-lbl">card@(totalQty == 1 ? "" : "s")</span>
                                            </span>
                                            <span class="tile-sep">·</span>
                                            <span class="tile-stat">
                                                <span class="tile-stat-val">@uniqueCount</span>
                                                <span class="tile-stat-lbl">unique</span>
                                            </span>
                                            @if (foilCount > 0)
                                            {
                                                <span class="tile-sep">·</span>
                                                <span class="tile-stat tile-stat-foil">
                                                    <span class="tile-stat-val">@foilCount</span>
                                                    <span class="tile-stat-lbl">foil</span>
                                                </span>
                                            }
                                        </div>

                                        <!-- Graph-style fill bar -->
                                        <div class="tile-graph-bar">
                                            <div class="tile-graph-fill" style="width: @fillPct%"></div>
                                        </div>

                                        @if (hasValue)
                                        {
                                            <div class="tile-value">$@totalValue.ToString("N2")</div>
                                        }
                                    </div>

                                    <!-- Arrow -->
                                    <div class="tile-arrow">
                                        <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                                            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
                                        </svg>
                                    </div>

                                </button>
                            }
                        </div>
                    }

                    <!-- Add new collection tile (ghost) -->
                    <button class="collection-tile-add" @onclick="OpenCreateModal">
                        <div class="tile-add-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                            </svg>
                        </div>
                        <span class="tile-add-label">New Collection</span>
                    </button>
                </div>
            }
        </main>

        <!-- ══════════════════════════════════════════
             CREATE COLLECTION MODAL (two-step)
             ══════════════════════════════════════════ -->
        @if (showCreateModal)
        {
            <div class="modal-backdrop" @onclick="CloseCreateModal">
                <div class="create-modal" @onclick:stopPropagation="true">
                    <div class="modal-header">
                        <h2 class="modal-title">@(modalStep == 1 ? "Choose Type" : "New Collection")</h2>
                        <button class="modal-close-btn" @onclick="CloseCreateModal">
                            <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18">
                                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
                            </svg>
                        </button>
                    </div>

                    @if (modalStep == 1)
                    {
                        <!-- Step 1: Type selection -->
                        <div class="modal-body">
                            <p class="modal-step-hint">What kind of collection is this?</p>
                            <div class="type-select-grid">
                                @foreach (var typeOpt in typeOptions)
                                {
                                    var tName = typeOpt.Name;
                                    <button class="type-select-card @(newCollectionType == tName ? $"type-select-active type-select-active-{tName.ToLower()}" : "")"
                                            @onclick="() => SelectType(tName)">
                                        <span class="type-select-icon">@typeOpt.Icon</span>
                                        <span class="type-select-name">@tName</span>
                                        <span class="type-select-desc">@typeOpt.Description</span>
                                    </button>
                                }
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button class="modal-cancel-btn" @onclick="CloseCreateModal">Cancel</button>
                            <button class="modal-create-btn" @onclick="() => modalStep = 2">
                                Next →
                            </button>
                        </div>
                    }
                    else
                    {
                        <!-- Step 2: Name + icon -->
                        <div class="modal-body">
                            <!-- Selected type chip -->
                            <div class="modal-selected-type">
                                <span class="type-badge type-badge-@newCollectionType.ToLower()">@newCollectionType</span>
                                <button class="modal-change-type-btn" @onclick="() => modalStep = 1">Change</button>
                            </div>

                            <!-- Name -->
                            <div class="modal-field">
                                <label class="modal-label">Collection Name</label>
                                <input class="modal-input"
                                       @bind="newCollectionName"
                                       @bind:event="oninput"
                                       placeholder="e.g. Binder 3, Cube, Trade Pile…"
                                       maxlength="40"
                                       @onkeydown="OnModalKeyDown" />
                            </div>

                            <!-- Icon picker -->
                            <div class="modal-field">
                                <label class="modal-label">Icon</label>
                                <div class="icon-picker-grid">
                                    @foreach (var icon in availableIcons)
                                    {
                                        <button class="icon-option @(newCollectionIcon == icon ? "icon-option-selected" : "")"
                                                @onclick="() => newCollectionIcon = icon">
                                            @icon
                                        </button>
                                    }
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(createError))
                            {
                                <p class="modal-error">@createError</p>
                            }
                        </div>
                        <div class="modal-footer">
                            <button class="modal-cancel-btn" @onclick="() => modalStep = 1">← Back</button>
                            <button class="modal-create-btn" @onclick="CreateCollection" disabled="@string.IsNullOrWhiteSpace(newCollectionName)">
                                <svg viewBox="0 0 20 20" fill="currentColor" width="15" height="15">
                                    <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/>
                                </svg>
                                Create
                            </button>
                        </div>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <!-- ══════════════════════════════════════════
             COLLECTION DETAIL VIEW
             ══════════════════════════════════════════ -->
        <header class="collection-header">
            <div class="col-header-inner">
                <button class="back-btn" @onclick="CloseCollection" title="Back to collections">
                    <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                        <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                    <span>Collections</span>
                </button>
                <h1 class="collection-title">
                    <span class="detail-title-icon">@ActiveGroup.Icon</span>
                    @ActiveGroup.Name
                </h1>
                <span class="detail-type-badge type-badge-@ActiveGroup.Type.ToLower()">@ActiveGroup.Type</span>
            </div>
        </header>

        <!-- Stats Bar -->
        <div class="stats-bar">
            <div class="stats-inner">
                <div class="stat-chip">
                    <span class="stat-icon">
                        <svg viewBox="0 0 20 20" fill="currentColor">
                            <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"/>
                            <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"/>
                        </svg>
                    </span>
                    <div class="stat-info">
                        <span class="stat-label">Total Cards</span>
                        <span class="stat-value">@TotalCards</span>
                    </div>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-chip">
                    <span class="stat-icon">
                        <svg viewBox="0 0 20 20" fill="currentColor">
                            <path d="M7 3a1 1 0 000 2h6a1 1 0 100-2H7zM4 7a1 1 0 011-1h10a1 1 0 110 2H5a1 1 0 01-1-1zM2 11a2 2 0 012-2h12a2 2 0 012 2v4a2 2 0 01-2 2H4a2 2 0 01-2-2v-4z"/>
                        </svg>
                    </span>
                    <div class="stat-info">
                        <span class="stat-label">Unique Cards</span>
                        <span class="stat-value">@UniqueCards</span>
                    </div>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-chip">
                    <span class="stat-icon stat-icon-gold">
                        <svg viewBox="0 0 20 20" fill="currentColor">
                            <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"/>
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"/>
                        </svg>
                    </span>
                    <div class="stat-info">
                        <span class="stat-label">Est. Value (USD)</span>
                        <span class="stat-value stat-value-gold">@EstimatedValue</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <main class="collection-main">

            @if (ActiveGroup.Cards.Count == 0)
            {
                <div class="empty-collection">
                    <div class="empty-icon-wrap">
                        <svg class="empty-svg" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="60" cy="60" r="56" stroke="rgba(236,201,75,0.15)" stroke-width="2"/>
                            <rect x="30" y="38" width="60" height="46" rx="5" stroke="rgba(236,201,75,0.25)" stroke-width="2" fill="none"/>
                            <rect x="38" y="30" width="60" height="46" rx="5" stroke="rgba(236,201,75,0.18)" stroke-width="2" fill="none"/>
                            <path d="M44 68 L54 52 L64 62 L72 46 L84 68" stroke="rgba(236,201,75,0.4)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                            <circle cx="54" cy="52" r="2" fill="rgba(236,201,75,0.5)"/>
                        </svg>
                    </div>
                    <h2 class="empty-title">@ActiveGroup.Name is empty</h2>
                    <p class="empty-subtitle">Find a card and add it to start building your collection!</p>
                    <button class="cta-btn" @onclick='() => Navigation.NavigateTo("/simplesearch")'>
                        <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                            <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
                        </svg>
                        Search Cards
                    </button>
                </div>
            }
            else if (ActiveGroup.Type == "Deck")
            {
                var mainCards = ActiveGroup.Cards.Where(c => c.IsMainboard).ToList();
                var sideCards = ActiveGroup.Cards.Where(c => !c.IsMainboard).ToList();
                var mainCount = mainCards.Sum(c => c.Quantity);
                var sideCount = sideCards.Sum(c => c.Quantity);
                var mainPct   = mainCount > 0 ? Math.Min(mainCount * 100 / 60, 100) : 0;
                var maxCurve  = Enumerable.Range(0, 8)
                    .Select(n => mainCards.Where(c => n == 7 ? c.Cmc >= 7 : c.Cmc == n).Sum(c => c.Quantity))
                    .DefaultIfEmpty(0).Max();
                var filteredMain = FilteredMainboard.ToList();
                var filteredSide = FilteredSideboard.ToList();

                <!-- Card count progress bar -->
                <div class="deck-progress-wrap">
                    <div class="deck-progress-label">
                        <span class="deck-count-main">@mainCount / 60 main</span>
                        @if (sideCount > 0)
                        {
                            <span class="deck-count-side">@sideCount sideboard</span>
                        }
                    </div>
                    <div class="deck-progress-track">
                        <div class="deck-progress-fill" style="width: @mainPct%"></div>
                    </div>
                </div>

                <!-- Mana curve chart -->
                <div class="mana-curve-wrap">
                    <div class="mana-curve-header">
                        <span class="mana-curve-title">Mana Curve</span>
                        <span class="mana-curve-subtitle">Mainboard only</span>
                    </div>
                    <div class="mana-curve-bars">
                        @for (int n = 0; n <= 7; n++)
                        {
                            var cmcIdx   = n;
                            var cmcLabel = cmcIdx == 7 ? "7+" : cmcIdx.ToString();
                            var cmcCount = mainCards
                                .Where(c => cmcIdx == 7 ? c.Cmc >= 7 : c.Cmc == cmcIdx)
                                .Sum(c => c.Quantity);
                            var barPct = maxCurve > 0 ? cmcCount * 100 / maxCurve : 0;
                            <div class="curve-col">
                                <div class="curve-bar-track">
                                    <div class="curve-bar-fill" style="height: @barPct%"></div>
                                </div>
                                <div class="curve-bar-count">@(cmcCount > 0 ? cmcCount.ToString() : "")</div>
                                <div class="curve-bar-cmc">@cmcLabel</div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Filter/Search Bar -->
                <div class="collection-toolbar">
                    <div class="collection-search-box">
                        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8"/>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        </svg>
                        <input class="collection-search-input"
                               @bind="filterQuery"
                               @bind:event="oninput"
                               placeholder="Search @ActiveGroup.Name..." />
                        @if (!string.IsNullOrEmpty(filterQuery))
                        {
                            <button class="clear-filter-btn" @onclick='() => filterQuery = ""'>
                                <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14">
                                    <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
                                </svg>
                            </button>
                        }
                    </div>
                    <span class="toolbar-count">@FilteredCollection.Count() card@(FilteredCollection.Count() == 1 ? "" : "s")</span>
                </div>

                <!-- Mainboard section -->
                <div class="deck-section-label">
                    <span class="deck-section-icon">📋</span>
                    Mainboard
                    <span class="deck-section-count">@mainCount</span>
                </div>
                @if (filteredMain.Any())
                {
                    <div class="collection-grid">
                        @foreach (var entry in filteredMain)
                        {
                            <div class="col-card @(entry.IsFoil ? "col-card-foil" : "")">
                                <div class="col-image-wrap">
                                    @if (!string.IsNullOrEmpty(entry.ImageUrl))
                                    {
                                        <img src="@entry.ImageUrl" class="col-card-img" alt="@entry.Name" loading="lazy" />
                                    }
                                    else
                                    {
                                        <div class="col-no-image"><span>🃏</span></div>
                                    }
                                    @if (entry.IsFoil)
                                    {
                                        <div class="foil-overlay"></div>
                                        <div class="foil-badge">✦ Foil</div>
                                    }
                                </div>
                                <div class="col-card-body">
                                    <h3 class="col-card-name">@entry.Name</h3>
                                    <div class="col-card-meta">
                                        <span class="col-set-name">@entry.SetName</span>
                                        <span class="col-set-code">@entry.SetCode.ToUpper()</span>
                                    </div>
                                    <div class="col-card-footer">
                                        <span class="condition-badge condition-@entry.Condition.ToLower()">@entry.Condition</span>
                                        <div class="qty-stepper">
                                            <button class="qty-btn" @onclick="() => Decrement(entry)" disabled="@(entry.Quantity <= 1)" title="Decrease">−</button>
                                            <span class="qty-value" title="Quantity">@entry.Quantity×</span>
                                            <button class="qty-btn" @onclick="() => Increment(entry)" title="Increase">+</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }

                <!-- Sideboard section -->
                @if (sideCards.Any())
                {
                    <div class="deck-section-label deck-section-sideboard">
                        <span class="deck-section-icon">🔀</span>
                        Sideboard
                        <span class="deck-section-count">@sideCount</span>
                    </div>
                    @if (filteredSide.Any())
                    {
                        <div class="collection-grid">
                            @foreach (var entry in filteredSide)
                            {
                                <div class="col-card col-card-sideboard @(entry.IsFoil ? "col-card-foil" : "")">
                                    <div class="col-image-wrap">
                                        @if (!string.IsNullOrEmpty(entry.ImageUrl))
                                        {
                                            <img src="@entry.ImageUrl" class="col-card-img" alt="@entry.Name" loading="lazy" />
                                        }
                                        else
                                        {
                                            <div class="col-no-image"><span>🃏</span></div>
                                        }
                                        @if (entry.IsFoil)
                                        {
                                            <div class="foil-overlay"></div>
                                            <div class="foil-badge">✦ Foil</div>
                                        }
                                    </div>
                                    <div class="col-card-body">
                                        <h3 class="col-card-name">@entry.Name</h3>
                                        <div class="col-card-meta">
                                            <span class="col-set-name">@entry.SetName</span>
                                            <span class="col-set-code">@entry.SetCode.ToUpper()</span>
                                        </div>
                                        <div class="col-card-footer">
                                            <span class="condition-badge condition-@entry.Condition.ToLower()">@entry.Condition</span>
                                            <div class="qty-stepper">
                                                <button class="qty-btn" @onclick="() => Decrement(entry)" disabled="@(entry.Quantity <= 1)" title="Decrease">−</button>
                                                <span class="qty-value" title="Quantity">@entry.Quantity×</span>
                                                <button class="qty-btn" @onclick="() => Increment(entry)" title="Increase">+</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
            }
            else if (ActiveGroup.Type == "Binder")
            {
                <!-- ── BINDER VIEW: paginated binder pockets ─────────────────── -->
                <div class="collection-toolbar">
                    <div class="collection-search-box">
                        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8"/>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        </svg>
                        <input class="collection-search-input"
                               value="@filterQuery"
                               @oninput="OnBinderFilterInput"
                               placeholder="Search @ActiveGroup.Name..." />
                        @if (!string.IsNullOrEmpty(filterQuery))
                        {
                            <button class="clear-filter-btn" @onclick='() => { filterQuery = ""; binderPage = 0; }'>
                                <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14">
                                    <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
                                </svg>
                            </button>
                        }
                    </div>
                    <span class="toolbar-count">@FilteredCollection.Count() card@(FilteredCollection.Count() == 1 ? "" : "s")</span>
                </div>

                @if (!FilteredCollection.Any())
                {
                    <div class="no-results-state">
                        <div class="no-results-icon">🔍</div>
                        <p>No cards match <strong>"@filterQuery"</strong></p>
                        <button class="clear-search-btn" @onclick='() => { filterQuery = ""; binderPage = 0; }'>Clear search</button>
                    </div>
                }
                else
                {
                    var pageCards  = FilteredCollection.Skip(binderPage * BinderCardsPerPage).Take(BinderCardsPerPage).ToList();
                    var totalPages = (int)Math.Ceiling(FilteredCollection.Count() / (double)BinderCardsPerPage);

                    <div class="binder-outer">
                        <!-- Rings spine -->
                        <div class="binder-spine">
                            <div class="binder-ring"></div>
                            <div class="binder-ring"></div>
                            <div class="binder-ring"></div>
                        </div>

                        <!-- Page (keyed so animation fires on page change) -->
                        <div class="binder-page" @key="binderPage">
                            <div class="binder-page-top">
                                <span class="binder-page-num">Page @(binderPage + 1) / @totalPages</span>
                            </div>

                            <!-- 3×3 pocket grid -->
                            <div class="binder-pockets">
                                @for (int i = 0; i < BinderCardsPerPage; i++)
                                {
                                    var slotIdx = i;
                                    var entry   = slotIdx < pageCards.Count ? pageCards[slotIdx] : null;
                                    <div class="binder-pocket @(entry == null ? "binder-pocket-empty" : "") @(entry?.IsFoil == true ? "binder-pocket-foil" : "")">
                                        @if (entry != null)
                                        {
                                            <div class="pocket-inner">
                                                @if (!string.IsNullOrEmpty(entry.ImageUrl))
                                                {
                                                    <img src="@entry.ImageUrl" class="pocket-card-img" alt="@entry.Name" loading="lazy" />
                                                }
                                                else
                                                {
                                                    <div class="pocket-no-image"><span>🃏</span></div>
                                                }
                                                @if (entry.IsFoil)
                                                {
                                                    <div class="foil-overlay"></div>
                                                }
                                                <div class="pocket-condition condition-@entry.Condition.ToLower()">@entry.Condition</div>
                                                @if (entry.Quantity > 1)
                                                {
                                                    <div class="pocket-qty"><span>×@entry.Quantity</span></div>
                                                }
                                                <div class="pocket-hover-info">
                                                    <span class="pocket-card-name">@entry.Name</span>
                                                    <span class="pocket-set-info">@entry.SetCode.ToUpper() · @entry.SetName</span>
                                                    <div class="pocket-stepper">
                                                        <button class="qty-btn" @onclick="() => Decrement(entry)" disabled="@(entry.Quantity <= 1)">−</button>
                                                        <span class="qty-value">@entry.Quantity×</span>
                                                        <button class="qty-btn" @onclick="() => Increment(entry)">+</button>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>

                            <!-- Page navigation -->
                            <div class="binder-nav">
                                <button class="binder-nav-btn" @onclick="BinderPrevPage" disabled="@(binderPage == 0)">← Prev</button>
                                <div class="binder-page-dots">
                                    @for (int p = 0; p < totalPages; p++)
                                    {
                                        var pi = p;
                                        <button class="binder-dot @(pi == binderPage ? "binder-dot-active" : "")" @onclick="() => BinderGoToPage(pi)"></button>
                                    }
                                </div>
                                <button class="binder-nav-btn" @onclick="BinderNextPage" disabled="@(binderPage >= totalPages - 1)">Next →</button>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <!-- ── BULK VIEW: compact card grid (unchanged) ───────────────── -->
                <div class="collection-toolbar">
                    <div class="collection-search-box">
                        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8"/>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        </svg>
                        <input class="collection-search-input"
                               @bind="filterQuery"
                               @bind:event="oninput"
                               placeholder="Search @ActiveGroup.Name..." />
                        @if (!string.IsNullOrEmpty(filterQuery))
                        {
                            <button class="clear-filter-btn" @onclick='() => filterQuery = ""'>
                                <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14">
                                    <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
                                </svg>
                            </button>
                        }
                    </div>
                    <span class="toolbar-count">@FilteredCollection.Count() card@(FilteredCollection.Count() == 1 ? "" : "s")</span>
                </div>

                @if (!FilteredCollection.Any())
                {
                    <div class="no-results-state">
                        <div class="no-results-icon">🔍</div>
                        <p>No cards match <strong>"@filterQuery"</strong></p>
                        <button class="clear-search-btn" @onclick='() => filterQuery = ""'>Clear search</button>
                    </div>
                }
                else
                {
                    <div class="collection-grid">
                        @foreach (var entry in FilteredCollection)
                        {
                            <div class="col-card @(entry.IsFoil ? "col-card-foil" : "")">
                                <div class="col-image-wrap">
                                    @if (!string.IsNullOrEmpty(entry.ImageUrl))
                                    {
                                        <img src="@entry.ImageUrl" class="col-card-img" alt="@entry.Name" loading="lazy" />
                                    }
                                    else
                                    {
                                        <div class="col-no-image"><span>🃏</span></div>
                                    }
                                    @if (entry.IsFoil)
                                    {
                                        <div class="foil-overlay"></div>
                                        <div class="foil-badge">✦ Foil</div>
                                    }
                                </div>
                                <div class="col-card-body">
                                    <h3 class="col-card-name">@entry.Name</h3>
                                    <div class="col-card-meta">
                                        <span class="col-set-name">@entry.SetName</span>
                                        <span class="col-set-code">@entry.SetCode.ToUpper()</span>
                                    </div>
                                    <div class="col-card-footer">
                                        <span class="condition-badge condition-@entry.Condition.ToLower()">@entry.Condition</span>
                                        <div class="qty-stepper">
                                            <button class="qty-btn" @onclick="() => Decrement(entry)" disabled="@(entry.Quantity <= 1)" title="Decrease">−</button>
                                            <span class="qty-value" title="Quantity">@entry.Quantity×</span>
                                            <button class="qty-btn" @onclick="() => Increment(entry)" title="Increase">+</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            }

        </main>
    }

</div>

@code {
    // ── Collection entry model ────────────────────────────────────────────────
    private class CollectionEntry
    {
        public string   Id          { get; set; } = Guid.NewGuid().ToString();
        public string   Name        { get; set; } = "";
        public string   SetName     { get; set; } = "";
        public string   SetCode     { get; set; } = "";
        public string?  ImageUrl    { get; set; }
        public string   Condition   { get; set; } = "NM";
        public bool     IsFoil      { get; set; }
        public int      Quantity    { get; set; } = 1;
        public decimal? PriceUsd    { get; set; }
        public int      Cmc         { get; set; } = 0;
        public bool     IsMainboard { get; set; } = true;
    }

    // ── Collection group model ─────────────────────────────────────────────────
    private class CollectionGroup
    {
        public string Key   { get; set; } = "";
        public string Name  { get; set; } = "";
        public string Icon  { get; set; } = "";
        public string Type  { get; set; } = "Bulk";
        public List<CollectionEntry> Cards { get; set; } = new();
    }

    // ── Type option descriptor ─────────────────────────────────────────────────
    private record TypeOption(string Name, string Icon, string Description);

    private static readonly TypeOption[] typeOptions = new[]
    {
        new TypeOption("Binder", "📗", "Organized card binder, sorted by set or value"),
        new TypeOption("Deck",   "🎴", "Built deck ready to play — 60 or 100 cards"),
        new TypeOption("Bulk",   "📦", "Unsorted bulk cards, trades, or storage"),
    };

    // ── State ─────────────────────────────────────────────────────────────────
    private string filterQuery       = "";
    private string collectionSearch  = "";
    private string activeTypeFilter  = "All";

    private string? selectedCollectionKey = null;

    // Create modal
    private bool   showCreateModal    = false;
    private int    modalStep          = 1;
    private string newCollectionName  = "";
    private string newCollectionIcon  = "📦";
    private string newCollectionType  = "Bulk";
    private string createError        = "";

    // Delete confirmation
    private string? pendingDeleteKey = null;

    // Binder pagination
    private int binderPage = 0;
    private const int BinderCardsPerPage = 9;

    private static readonly string[] availableIcons = new[]
    {
        "📦", "📗", "📘", "📙", "📕", "🎴", "🃏", "⚔️", "🛡️",
        "🏆", "💎", "🌟", "✨", "🔮", "🧙", "🐉", "🌙", "⬡"
    };

    // ── All collections ────────────────────────────────────────────────────────
    private List<CollectionGroup> allCollections = new()
    {
        new()
        {
            Key = "bulk", Name = "Bulk", Icon = "📦", Type = "Bulk",
            Cards = new()
            {
                new() { Name = "Lightning Bolt",   SetName = "Alpha",             SetCode = "LEA", Condition = "NM", IsFoil = false, Quantity = 4, PriceUsd = 1.50m,  Cmc = 1 },
                new() { Name = "Counterspell",     SetName = "Masters Edition 4", SetCode = "ME4", Condition = "NM", IsFoil = false, Quantity = 4, PriceUsd = 1.25m,  Cmc = 2 },
                new() { Name = "Sol Ring",         SetName = "Commander Masters", SetCode = "CMM", Condition = "MP", IsFoil = false, Quantity = 3, PriceUsd = 2.75m,  Cmc = 1 },
            }
        },
        new()
        {
            Key = "binder1", Name = "Binder 1", Icon = "📗", Type = "Binder",
            Cards = new()
            {
                new() { Name = "Black Lotus",   SetName = "Limited Edition Alpha", SetCode = "LEA", Condition = "NM", IsFoil = false, Quantity = 1, PriceUsd = 45000m, Cmc = 0 },
                new() { Name = "Mox Diamond",   SetName = "Stronghold",            SetCode = "STH", Condition = "HP", IsFoil = false, Quantity = 1, PriceUsd = 220m,   Cmc = 0 },
                new() { Name = "Force of Will", SetName = "Alliances",             SetCode = "ALL", Condition = "LP", IsFoil = false, Quantity = 2, PriceUsd = 75m,    Cmc = 5 },
            }
        },
        new()
        {
            Key = "binder2", Name = "Binder 2", Icon = "📘", Type = "Binder",
            Cards = new()
            {
                new() { Name = "Jace, the Mind Sculptor", SetName = "Worldwake",       SetCode = "WWK", Condition = "LP",  IsFoil = true,  Quantity = 2, PriceUsd = 55.99m, Cmc = 4 },
                new() { Name = "Wrenn and Six",           SetName = "Modern Horizons", SetCode = "MH1", Condition = "DMG", IsFoil = false, Quantity = 1, PriceUsd = 45m,    Cmc = 2 },
            }
        },
        new()
        {
            Key = "deck1", Name = "Deck 1", Icon = "🎴", Type = "Deck",
            Cards = new()
            {
                new() { Name = "Ragavan, Nimble Pilferer", SetName = "Modern Horizons 2", SetCode = "MH2", Condition = "NM", Quantity = 3, PriceUsd = 40m,   Cmc = 1, IsMainboard = true  },
                new() { Name = "Lightning Bolt",           SetName = "Alpha",             SetCode = "LEA", Condition = "NM", Quantity = 4, PriceUsd = 1.50m, Cmc = 1, IsMainboard = true  },
                new() { Name = "Counterspell",             SetName = "Masters Edition 4", SetCode = "ME4", Condition = "NM", Quantity = 4, PriceUsd = 1.25m, Cmc = 2, IsMainboard = true  },
                new() { Name = "Force of Will",            SetName = "Alliances",         SetCode = "ALL", Condition = "NM", Quantity = 4, PriceUsd = 75m,   Cmc = 5, IsMainboard = true  },
                new() { Name = "Surgical Extraction",      SetName = "New Phyrexia",      SetCode = "NPH", Condition = "NM", Quantity = 2, PriceUsd = 3.50m, Cmc = 1, IsMainboard = false },
            }
        },
        new()
        {
            Key = "deck2", Name = "Deck 2", Icon = "🃏", Type = "Deck",
            Cards = new()
            {
                new() { Name = "Orcish Bowmasters", SetName = "Lord of the Rings", SetCode = "LTR", Condition = "NM", IsFoil = true,  Quantity = 2, PriceUsd = 22m,   Cmc = 2, IsMainboard = true  },
                new() { Name = "Sol Ring",          SetName = "Commander Masters", SetCode = "CMM", Condition = "NM", IsFoil = true,  Quantity = 1, PriceUsd = 2.75m, Cmc = 1, IsMainboard = true  },
                new() { Name = "Counterspell",      SetName = "Masters Edition 4", SetCode = "ME4", Condition = "NM", IsFoil = false, Quantity = 4, PriceUsd = 1.25m, Cmc = 2, IsMainboard = true  },
                new() { Name = "Force of Nature",   SetName = "Revised Edition",   SetCode = "3ED", Condition = "LP", IsFoil = false, Quantity = 2, PriceUsd = 0.50m, Cmc = 6, IsMainboard = false },
            }
        },
    };

    // ── Filtered collections list ──────────────────────────────────────────────
    private IEnumerable<CollectionGroup> FilteredCollections =>
        allCollections
            .Where(g => activeTypeFilter == "All" || g.Type == activeTypeFilter)
            .Where(g => string.IsNullOrWhiteSpace(collectionSearch) ||
                g.Name.Contains(collectionSearch, StringComparison.OrdinalIgnoreCase));

    // ── Active group ───────────────────────────────────────────────────────────
    private CollectionGroup ActiveGroup =>
        allCollections.FirstOrDefault(g => g.Key == selectedCollectionKey) ?? allCollections[0];

    // ── Computed properties ────────────────────────────────────────────────────
    private IEnumerable<CollectionEntry> FilteredCollection =>
        string.IsNullOrWhiteSpace(filterQuery)
            ? ActiveGroup.Cards
            : ActiveGroup.Cards.Where(e =>
                e.Name.Contains(filterQuery, StringComparison.OrdinalIgnoreCase) ||
                e.SetName.Contains(filterQuery, StringComparison.OrdinalIgnoreCase) ||
                e.SetCode.Contains(filterQuery, StringComparison.OrdinalIgnoreCase));

    private IEnumerable<CollectionEntry> FilteredMainboard =>
        FilteredCollection.Where(c => c.IsMainboard);

    private IEnumerable<CollectionEntry> FilteredSideboard =>
        FilteredCollection.Where(c => !c.IsMainboard);

    private int    TotalCards     => ActiveGroup.Cards.Sum(e => e.Quantity);
    private int    UniqueCards    => ActiveGroup.Cards.Count;
    private string EstimatedValue => ActiveGroup.Cards.Any(e => e.PriceUsd.HasValue)
        ? "$" + ActiveGroup.Cards.Sum(e => (e.PriceUsd ?? 0m) * e.Quantity).ToString("N2")
        : "N/A";

    // ── Navigation ─────────────────────────────────────────────────────────────
    private void OpenCollection(string key)
    {
        selectedCollectionKey = key;
        filterQuery = "";
        pendingDeleteKey = null;
        binderPage = 0;
    }

    private void CloseCollection()
    {
        selectedCollectionKey = null;
        filterQuery = "";
        binderPage = 0;
    }

    // ── Binder pagination ──────────────────────────────────────────────────────
    private void BinderPrevPage()
    {
        if (binderPage > 0) binderPage--;
    }

    private void BinderNextPage()
    {
        var totalPages = (int)Math.Ceiling(FilteredCollection.Count() / (double)BinderCardsPerPage);
        if (binderPage < totalPages - 1) binderPage++;
    }

    private void BinderGoToPage(int page) => binderPage = page;

    private void OnBinderFilterInput(ChangeEventArgs e)
    {
        filterQuery = e.Value?.ToString() ?? "";
        binderPage = 0;
    }

    // ── Create collection modal ────────────────────────────────────────────────
    private void OpenCreateModal()
    {
        newCollectionName  = "";
        newCollectionIcon  = "📦";
        newCollectionType  = "Bulk";
        createError        = "";
        modalStep          = 1;
        showCreateModal    = true;
    }

    private void CloseCreateModal()
    {
        showCreateModal = false;
        createError     = "";
        modalStep       = 1;
    }

    private void SelectType(string type)
    {
        newCollectionType = type;
        newCollectionIcon = type switch
        {
            "Binder" => "📗",
            "Deck"   => "🎴",
            _        => "📦",
        };
        modalStep = 2;
    }

    private void CreateCollection()
    {
        var name = newCollectionName.Trim();
        if (string.IsNullOrEmpty(name)) return;

        if (allCollections.Any(g => g.Name.Equals(name, StringComparison.OrdinalIgnoreCase)))
        {
            createError = "A collection with that name already exists.";
            return;
        }

        var key = Guid.NewGuid().ToString("N")[..8];
        allCollections.Add(new CollectionGroup
        {
            Key   = key,
            Name  = name,
            Icon  = newCollectionIcon,
            Type  = newCollectionType,
            Cards = new()
        });

        ToastService.Show($"Created \"{name}\"");
        showCreateModal = false;
        createError     = "";
        modalStep       = 1;
    }

    private void OnModalKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && modalStep == 2) CreateCollection();
        if (e.Key == "Escape") CloseCreateModal();
    }

    // ── Delete collection ──────────────────────────────────────────────────────
    private void RequestDelete(string key)  => pendingDeleteKey = key;
    private void CancelDelete()             => pendingDeleteKey = null;

    private void ConfirmDelete(string key)
    {
        var group = allCollections.FirstOrDefault(g => g.Key == key);
        if (group is null) return;

        allCollections.Remove(group);
        pendingDeleteKey = null;
        ToastService.Show($"Deleted \"{group.Name}\"");
    }

    // ── Quantity stepper ───────────────────────────────────────────────────────
    private void Increment(CollectionEntry entry)
    {
        entry.Quantity++;
        ToastService.Show($"Updated {entry.Name} to {entry.Quantity}×");
    }

    private void Decrement(CollectionEntry entry)
    {
        if (entry.Quantity > 1)
        {
            entry.Quantity--;
            ToastService.Show($"Updated {entry.Name} to {entry.Quantity}×");
        }
    }
}
