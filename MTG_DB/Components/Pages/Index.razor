@page "/"
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>MTG Hub - Magic: The Gathering Collection Manager</PageTitle>

<link href="css/index.razor.css" rel="stylesheet" />

<div class="landing-page">
    <!-- Magic: The Gathering Art Slideshow Background -->
    <div class="mtg-background">
        @for (int i = 0; i < BackgroundImages.Length; i++)
        {
            <div class="bg-slide @(currentSlide == i ? "active" : "")"
                 style="background-image: url('@BackgroundImages[i]');">
                <div class="bg-overlay"></div>
            </div>
        }
        <div class="bg-controls">
            @for (int i = 0; i < BackgroundImages.Length; i++)
            {
                <button class="bg-dot @(currentSlide == i ? "active" : "")"
                        @onclick="() => ChangeSlide(i)"></button>
            }
        </div>
    </div>

    <!-- Hero Content -->
    <div class="hero-section d-flex align-items-center min-vh-100">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8 col-xl-7 text-center">
                    <!-- Logo -->
                    <div class="mb-5">
                        <h1 class="hero-logo gradient-text mb-4">MTG HUB</h1>
                        <div class="tagline-container">
                            <span class="tagline-badge">Magic: The Gathering</span>
                            <span class="tagline-text">Collection Manager</span>
                        </div>
                    </div>

                    <!-- Main Search Box -->
                    <div class="search-hero mb-5">
                        <div class="search-container">
                            <div class="search-wrapper">
                                <div class="search-icon">
                                    <i class="bi bi-search"></i>
                                </div>
                                <input type="text"
                                       class="search-input"
                                       placeholder="Search for any Magic card, set, or type..."
                                       @bind="searchQuery"
                                       @bind:event="oninput"
                                       @onkeypress="HandleSearchKeyPress" />
                                <button class="search-button" @onclick="NavigateToSearch">
                                    <span>Search Cards</span>
                                    <i class="bi bi-arrow-right ms-2"></i>
                                </button>
                            </div>
                            <div class="search-examples mt-3">
                                <div class="d-flex flex-wrap gap-2 justify-content-center">
                                    <span class="search-example">Black Lotus</span>
                                    <span class="search-example">Island</span>
                                    <span class="search-example">Teferi, Time Raveler</span>
                                    <span class="search-example">Commander 2022</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Quick Stats -->
                    <div class="stats-section mb-5">
                        <div class="row g-3 justify-content-center">
                            <div class="col-auto">
                                <div class="stat-card">
                                    <div class="stat-icon">
                                        <i class="bi bi-card-text"></i>
                                    </div>
                                    <div class="stat-content">
                                        <div class="stat-number">30,000+</div>
                                        <div class="stat-label">Magic Cards</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-auto">
                                <div class="stat-card">
                                    <div class="stat-icon">
                                        <i class="bi bi-stack"></i>
                                    </div>
                                    <div class="stat-content">
                                        <div class="stat-number">500+</div>
                                        <div class="stat-label">Sets & Editions</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-auto">
                                <div class="stat-card">
                                    <div class="stat-icon">
                                        <i class="bi bi-graph-up-arrow"></i>
                                    </div>
                                    <div class="stat-content">
                                        <div class="stat-number">Real-time</div>
                                        <div class="stat-label">Market Prices</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Quick Actions -->
                    <div class="quick-actions mt-5">
                        <div class="row g-3 justify-content-center">
                            <div class="col-auto">
                                <button class="btn action-btn action-primary"
                                        @onclick='() => Navigation.NavigateTo("/simplesearch")'>
                                    <i class="bi bi-grid-3x3-gap me-2"></i>
                                    Browse All Cards
                                </button>
                            </div>
                            <div class="col-auto">
                                <button class="btn action-btn action-secondary"
                                        @onclick='() => Navigation.NavigateTo("/collection")'>
                                    <i class="bi bi-collection me-2"></i>
                                    View My Collection
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="landing-footer py-4">
        <div class="container">
            <div class="text-center">
                <p class="text-white mb-1">
                    Data provided by Scryfall API
                </p>
                <p class="text-light-small">
                    Not affiliated with Wizards of the Coast
                </p>
            </div>
        </div>
    </footer>
</div>

@code {
    private string searchQuery = "";
    private int currentSlide = 0;
    private Timer? slideshowTimer;

    // Using high-quality Magic: The Gathering art from Scryfall (art crop images)
    private readonly string[] BackgroundImages = new[]
    {
    // Card: Academy Elite
    "https://cards.scryfall.io/art_crop/front/a/a/aaa212be-1db5-4493-86c8-c01d29348e31.jpg?1752947648",
    // Card: Addle
    "https://cards.scryfall.io/art_crop/front/a/a/aaa212be-1db5-4493-86c8-c01d29348e31.jpg?1752947648",
    // Card: Aether Mutation
    "https://cards.scryfall.io/art_crop/front/5/3/5386a61c-4928-4bd1-babe-5b089ab8b2d9.jpg?1562911996"
};

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await StartSlideshow();
        }
    }

    private async Task StartSlideshow()
    {
        slideshowTimer = new Timer(async _ =>
        {
            await InvokeAsync(() =>
            {
                currentSlide = (currentSlide + 1) % BackgroundImages.Length;
                StateHasChanged();
            });
        }, null, 5000, 5000);
    }

    private void ChangeSlide(int slideIndex)
    {
        currentSlide = slideIndex;
        StateHasChanged();
    }

    private void HandleSearchKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            NavigateToSearch();
        }
    }

    private void NavigateToSearch()
    {
        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            Navigation.NavigateTo($"/simplesearch?query={Uri.EscapeDataString(searchQuery)}");
        }
        else
        {
            Navigation.NavigateTo("/simplesearch");
        }
    }

    public void Dispose()
    {
        slideshowTimer?.Dispose();
    }
}