@page "/card/{id}"
@rendermode InteractiveServer
@using MTG_DB.Models
@using MtgInventoryApp.Models
@using MtgInventoryApp.Services
@inject MtgInventoryApp.Services.ScryfallService Scryfall
@inject MtgInventoryApp.Services.CryptMtgService CryptMtg
@inject MtgInventoryApp.Services.SettingsService Settings
@inject ToastService ToastService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>MTGHUB - @(card?.Name ?? "Card Details")</PageTitle>

<div class="card-details-page">
    <!-- Header -->
    <header class="details-header">
        <div class="header-content">
            <h1 class="logo" @onclick='() => Navigation.NavigateTo("/")'>MTGHUB</h1>
            <button class="back-btn" @onclick="GoBack">
                ← Back to Search
            </button>
        </div>
    </header>

    <!-- Main Content -->
    <main class="details-main">
        @if (isLoading)
        {
            <div class="card-details-container">
                <div class="card-image-section">
                    <div class="image-container">
                        <div class="skeleton-image-large"></div>
                    </div>
                </div>
                <div class="card-info-section">
                    <div class="card-header">
                        <div class="skeleton-line skeleton-title"></div>
                        <div class="skeleton-line skeleton-badge"></div>
                    </div>
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="info-group">
                            <div class="skeleton-line skeleton-group-label"></div>
                            <div class="skeleton-grid-2">
                                <div class="skeleton-line"></div>
                                <div class="skeleton-line"></div>
                                <div class="skeleton-line skeleton-line-short"></div>
                                <div class="skeleton-line skeleton-line-short"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        else if (hasError)
        {
            <div class="error-state-details">
                <div class="error-icon-large">⚠️</div>
                <h2>Failed to Load Card</h2>
                <p>@errorMessage</p>
                <div class="error-actions">
                    <button class="action-btn primary" @onclick="LoadCardData">Retry</button>
                    <button class="back-btn" @onclick="GoBack">← Back to Search</button>
                </div>
            </div>
        }
        else if (card != null)
        {
            <div class="card-details-container">
                <!-- Left Column — Card Image (sticky) -->
                <div class="card-image-section">
                    <div class="image-container">
                        @{
                            var cardImageUrl = selectedPrintImageUrl ?? GetCardImage(card);
                        }
                        @if (!string.IsNullOrEmpty(cardImageUrl))
                        {
                            <img src="@cardImageUrl"
                                 class="main-card-image"
                                 alt="@card.Name"
                                 @onclick='() => JS.InvokeVoidAsync("window.open", cardImageUrl, "_blank")' />
                            <div class="image-size-note">
                                @if (selectedPrintId != null)
                                {
                                    <span>Selected printing — </span><button class="reset-preview-btn" @onclick="ResetPreview">Show original</button>
                                }
                                else
                                {
                                    <span>Click to view full size</span>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="no-image-large">
                                <span>🃏</span>
                                <p>No image available</p>
                            </div>
                        }

                        @if (IsDoubleFacedCard(card))
                        {
                            <div class="dfc-controls">
                                <button class="dfc-btn @(showBackFace ? "active" : "")"
                                        @onclick="ToggleCardFace">
                                    @if (showBackFace)
                                    {
                                        <span>↩ Show Front</span>
                                    }
                                    else
                                    {
                                        <span>↪ Show Back</span>
                                    }
                                </button>
                            </div>
                        }
                    </div>
                </div>

                <!-- Right Column — Tabbed Info Panel -->
                <div class="card-info-section">
                    <!-- Card Header (always visible) -->
                    <div class="card-header">
                        <h1 class="card-title">@card.Name</h1>
                        <div class="card-meta-row">
                            <div class="card-set-badge">
                                <img src="https://svgs.scryfall.io/sets/@(card.Set.ToLower()).svg"
                                     class="set-symbol"
                                     alt="@card.SetName"
                                     onerror="this.style.display='none'" />
                                <span class="set-name">@card.SetName</span>
                                <span class="set-code">@card.Set.ToUpper()</span>
                            </div>
                            <span class="rarity-badge rarity-@card.Rarity?.ToLower()">
                                @GetRarityDisplay(card.Rarity)
                            </span>
                        </div>
                    </div>

                    <!-- Bootstrap Tabs -->
                    <ul class="details-tabs">
                        <li><button class="tab-btn @(activeTab == "overview" ? "active" : "")" @onclick='() => SetTab("overview")'>Overview</button></li>
                        <li><button class="tab-btn @(activeTab == "prices" ? "active" : "")" @onclick='() => SetTab("prices")'>Prices</button></li>
                        <li><button class="tab-btn @(activeTab == "rulings" ? "active" : "")" @onclick='() => SetTab("rulings")'>Rulings</button></li>
                        <li><button class="tab-btn @(activeTab == "prints" ? "active" : "")" @onclick='() => SetTab("prints")'>Prints</button></li>
                    </ul>

                    <!-- Tab Panels -->
                    <div class="tab-content">

                        @* ── Overview ── *@
                        @if (activeTab == "overview")
                        {
                            <div class="info-group">
                                <h3>Card Details</h3>
                                <div class="info-grid">
                                    <div class="info-item">
                                        <span class="label">Mana Cost</span>
                                        <span class="value">@(card.ManaCost ?? "—")</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="label">Type</span>
                                        <span class="value">@(card.TypeLine ?? "—")</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="label">CMC</span>
                                        <span class="value">@(card.Cmc > 0 ? card.Cmc.ToString("G") : "—")</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="label">Collector #</span>
                                        <span class="value">@(card.CollectorNumber ?? "—")</span>
                                    </div>
                                </div>
                            </div>

                            <div class="info-group">
                                <h3>Rules Text</h3>
                                <div class="rules-text">
                                    @if (!string.IsNullOrEmpty(card.OracleText))
                                    {
                                        @card.OracleText
                                    }
                                    else if (IsDoubleFacedCard(card))
                                    {
                                        @foreach (var face in card.CardFaces)
                                        {
                                            <div class="dfc-face-rules">
                                                <strong>@face.Name</strong>
                                                <p>@(face.OracleText ?? "—")</p>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <p class="text-muted">No rules text.</p>
                                    }
                                </div>
                            </div>

                            <div class="info-group">
                                <h3>Stats</h3>
                                <div class="stats-grid">
                                    <div class="stat-item">
                                        <span class="stat-label">Power</span>
                                        <span class="stat-value">@(card.Power ?? "—")</span>
                                    </div>
                                    <div class="stat-item">
                                        <span class="stat-label">Toughness</span>
                                        <span class="stat-value">@(card.Toughness ?? "—")</span>
                                    </div>
                                    <div class="stat-item">
                                        <span class="stat-label">Loyalty</span>
                                        <span class="stat-value">@(card.Loyalty ?? "—")</span>
                                    </div>
                                    <div class="stat-item">
                                        <span class="stat-label">CMC</span>
                                        <span class="stat-value">@(card.Cmc > 0 ? card.Cmc.ToString("G") : "—")</span>
                                    </div>
                                </div>
                            </div>

                            <div class="info-group">
                                <h3>Additional Information</h3>
                                <div class="additional-info">
                                    <div class="info-row">
                                        <span class="info-label">Artist</span>
                                        <span class="info-value">@(card.Artist ?? "—")</span>
                                    </div>
                                    <div class="info-row">
                                        <span class="info-label">Border</span>
                                        <span class="info-value">@(card.BorderColor ?? "—")</span>
                                    </div>
                                    <div class="info-row">
                                        <span class="info-label">Frame</span>
                                        <span class="info-value">@(card.Frame ?? "—")</span>
                                    </div>
                                    <div class="info-row">
                                        <span class="info-label">Language</span>
                                        <span class="info-value">@(card.Lang ?? "—")</span>
                                    </div>
                                </div>
                            </div>

                            <div class="actions-section">
                                <button class="action-btn primary" @onclick="ToggleCollectionForm">
                                    @if (showCollectionForm)
                                    {
                                        <span>✕ Cancel</span>
                                    }
                                    else
                                    {
                                        <span>+ Add to Collection</span>
                                    }
                                </button>
                                <button class="action-btn secondary" @onclick="AddToDeck">+ Add to Deck</button>
                                <button class="action-btn tertiary" @onclick="ShareCard">📤 Share</button>
                            </div>

                            @if (showCollectionForm)
                            {
                                <div class="add-collection-form">
                                    <div class="form-row">
                                        <div class="form-field">
                                            <label class="form-label">Condition</label>
                                            <select class="form-select" @bind="addCondition">
                                                <option value="NM">NM — Near Mint</option>
                                                <option value="LP">LP — Lightly Played</option>
                                                <option value="MP">MP — Moderately Played</option>
                                                <option value="HP">HP — Heavily Played</option>
                                                <option value="DMG">DMG — Damaged</option>
                                            </select>
                                        </div>
                                        <div class="form-field form-field-qty">
                                            <label class="form-label">Qty</label>
                                            <div class="add-qty-stepper">
                                                <button class="add-qty-btn" @onclick="DecrementAddQty" disabled="@(addQuantity <= 1)">−</button>
                                                <span class="add-qty-val">@addQuantity</span>
                                                <button class="add-qty-btn" @onclick="IncrementAddQty">+</button>
                                            </div>
                                        </div>
                                        <div class="form-field form-field-foil">
                                            <label class="form-label">Foil</label>
                                            <label class="foil-toggle">
                                                <input type="checkbox" @bind="addIsFoil" />
                                                <span class="foil-toggle-track">
                                                    <span class="foil-toggle-thumb"></span>
                                                </span>
                                            </label>
                                        </div>
                                    </div>
                                    <button class="add-confirm-btn" @onclick="ConfirmAddToCollection">
                                        <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                        </svg>
                                        Add @addQuantity× @(addIsFoil ? "Foil" : "") @(addCondition) to Collection
                                    </button>
                                </div>
                            }
                        }

                        @* ── Prices ── *@
                        else if (activeTab == "prices")
                        {
                            <div class="info-group">
                                <h3>Market Prices</h3>
                                <table class="prices-table">
                                    <thead>
                                        <tr>
                                            <th>Format</th>
                                            <th>Regular</th>
                                            <th>Foil</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>@(Settings.IsCAD ? "CAD (est.)" : "USD")</td>
                                            <td>@Settings.FormatUsdPrice(card.Prices?.Usd)</td>
                                            <td>@Settings.FormatUsdPrice(card.Prices?.UsdFoil)</td>
                                        </tr>
                                        <tr>
                                            <td>@(Settings.IsCAD ? "CAD Etched (est.)" : "USD Etched")</td>
                                            <td>@Settings.FormatUsdPrice(card.Prices?.UsdEtched)</td>
                                            <td>—</td>
                                        </tr>
                                        <tr>
                                            <td>EUR</td>
                                            <td>@FormatPrice(card.Prices?.Eur, "€")</td>
                                            <td>@FormatPrice(card.Prices?.EurFoil, "€")</td>
                                        </tr>
                                        <tr>
                                            <td>MTGO (Tix)</td>
                                            <td>@FormatPrice(card.Prices?.Tix, "")</td>
                                            <td>—</td>
                                        </tr>
                                    </tbody>
                                </table>
                                <p class="price-note">Prices sourced from <a href="https://scryfall.com" target="_blank" rel="noopener">Scryfall</a>. Updated daily.</p>
                            </div>

                            <!-- La Crypte Price Widget -->
                            <div class="crypt-price-widget">
                                <div class="crypt-widget-header">
                                    <span class="crypt-maple">🍁</span>
                                    <h3 class="crypt-title">La Crypte</h3>
                                    <span class="cad-badge">CAD</span>
                                </div>

                                @if (isLoadingCryptPrice)
                                {
                                    <div class="crypt-skeleton-body">
                                        <div class="skeleton-line" style="width:60%;height:14px;margin-bottom:8px;"></div>
                                        <div class="skeleton-line" style="width:60%;height:14px;margin-bottom:16px;"></div>
                                        <div class="skeleton-line" style="width:40%;height:36px;border-radius:8px;"></div>
                                    </div>
                                }
                                else if (cryptPrice == null)
                                {
                                    <p class="crypt-unavailable">Unable to fetch La Crypte pricing at this time.</p>
                                }
                                else if (!cryptPrice.RegularNM.HasValue && !cryptPrice.FoilNM.HasValue)
                                {
                                    <div class="crypt-not-listed">
                                        <span class="crypt-not-listed-icon">—</span>
                                        <p>Not currently listed at La Crypte.</p>
                                    </div>
                                }
                                else
                                {
                                    <table class="crypt-prices-table">
                                        <tbody>
                                            <tr>
                                                <td class="crypt-format">Regular NM</td>
                                                <td class="crypt-price">@(cryptPrice.RegularNM.HasValue ? $"CA${cryptPrice.RegularNM.Value:F2}" : "—")</td>
                                            </tr>
                                            <tr>
                                                <td class="crypt-format">Foil NM</td>
                                                <td class="crypt-price">@(cryptPrice.FoilNM.HasValue ? $"CA${cryptPrice.FoilNM.Value:F2}" : "—")</td>
                                            </tr>
                                        </tbody>
                                    </table>

                                    @if (cryptPrice.AvailableInFrench)
                                    {
                                        <span class="crypt-fr-badge">🇫🇷 French available</span>
                                    }

                                    @if (!string.IsNullOrEmpty(cryptPrice.ProductUrl))
                                    {
                                        <a href="@cryptPrice.ProductUrl" target="_blank" rel="noopener" class="crypt-buy-btn">
                                            🛒 Buy at La Crypte
                                        </a>
                                    }
                                }
                            </div>
                        }

                        @* ── Rulings ── *@
                        else if (activeTab == "rulings")
                        {
                            @if (isLoadingRulings)
                            {
                                <div class="tab-loading">
                                    <div class="tab-spinner"></div>
                                    <span>Loading rulings…</span>
                                </div>
                            }
                            else if (rulings != null && rulings.Count > 0)
                            {
                                <div class="rulings-list">
                                    @foreach (var ruling in rulings)
                                    {
                                        <div class="ruling-item">
                                            <div class="ruling-meta">
                                                <span class="ruling-source">@GetSourceLabel(ruling.Source)</span>
                                                <span class="ruling-date">@ruling.PublishedAt</span>
                                            </div>
                                            <p class="ruling-comment">@ruling.Comment</p>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="empty-state">
                                    <span>📜</span>
                                    <p>No rulings found for this card.</p>
                                </div>
                            }
                        }

                        @* ── Prints ── *@
                        else if (activeTab == "prints")
                        {
                            @if (isLoadingPrints)
                            {
                                <div class="tab-loading">
                                    <div class="tab-spinner"></div>
                                    <span>Loading printings…</span>
                                </div>
                            }
                            else if (prints != null && prints.Count > 0)
                            {
                                <div class="prints-grid">
                                    @foreach (var print in prints)
                                    {
                                        var printImg = print.ImageUris?.Normal ?? print.CardFaces?.FirstOrDefault()?.ImageUris?.Normal;
                                        var printId = print.Id;
                                        <div class="print-card @(selectedPrintId == print.Id ? "print-selected" : "")" @onclick="() => SelectPrint(print)">
                                            @if (!string.IsNullOrEmpty(printImg))
                                            {
                                                <img src="@printImg" alt="@print.SetName" class="print-thumb" />
                                            }
                                            else
                                            {
                                                <div class="print-thumb-placeholder">🃏</div>
                                            }
                                            <div class="print-info">
                                                <div class="print-set">@print.SetName</div>
                                                <div class="print-num">#@print.CollectorNumber · @GetRarityDisplay(print.Rarity)</div>
                                                @if (!string.IsNullOrEmpty(print.Prices?.Usd))
                                                {
                                                    <div class="print-price">@Settings.FormatUsdPrice(print.Prices.Usd)</div>
                                                }
                                                <div class="print-actions">
                                                    <button class="print-navigate-btn" @onclick:stopPropagation="true" @onclick="() => NavigateToCard(printId)">View card →</button>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="empty-state">
                                    <span>🃏</span>
                                    <p>No other printings found.</p>
                                </div>
                            }
                        }

                    </div>
                </div>
            </div>
        }
    </main>
</div>

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    [Parameter]
    [SupplyParameterFromQuery]
    public string? ReturnQuery { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public int ReturnPage { get; set; } = 1;

    private ScryfallCard? card;
    private bool isLoading = true;
    private bool hasError;
    private string? errorMessage;
    private bool showBackFace = false;
    private string activeTab = "overview";

    private CryptMtgPrice? cryptPrice;
    private bool isLoadingCryptPrice;

    private List<ScryfallRuling>? rulings;
    private bool isLoadingRulings;

    private List<ScryfallCard>? prints;
    private bool isLoadingPrints;

    private string? selectedPrintId = null;
    private string? selectedPrintImageUrl = null;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(Id))
            await LoadCardData();
        else
            isLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Settings.LoadAsync(JS);
            StateHasChanged();
        }
    }

    private async Task LoadCardData()
    {
        isLoading = true;
        hasError = false;
        errorMessage = null;
        card = null;
        StateHasChanged();

        try
        {
            card = await Scryfall.GetCardByIdAsync(Id);
            if (card == null)
            {
                hasError = true;
                errorMessage = "Card not found.";
                ToastService.Show("Card not found.");
            }
            else
            {
                _ = LoadCryptPrice(card.Name);
            }
        }
        catch (HttpRequestException)
        {
            hasError = true;
            errorMessage = "Network error — check your connection and try again.";
            ToastService.Show(errorMessage);
        }
        catch (Exception ex)
        {
            hasError = true;
            errorMessage = $"Failed to load card: {ex.Message}";
            ToastService.Show(errorMessage);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void SetTab(string tab)
    {
        if (activeTab == tab) return;
        activeTab = tab;

        if (tab == "rulings" && rulings == null)
            _ = LoadRulings();
        else if (tab == "prints" && prints == null)
            _ = LoadPrints();
    }

    private async Task LoadCryptPrice(string name)
    {
        isLoadingCryptPrice = true;
        StateHasChanged();
        cryptPrice = await CryptMtg.GetPriceAsync(name);
        isLoadingCryptPrice = false;
        StateHasChanged();
    }

    private async Task LoadRulings()
    {
        isLoadingRulings = true;
        StateHasChanged();
        rulings = await Scryfall.GetRulingsAsync(Id);
        isLoadingRulings = false;
        StateHasChanged();
    }

    private async Task LoadPrints()
    {
        if (card == null) return;
        isLoadingPrints = true;
        StateHasChanged();
        prints = await Scryfall.GetPrintsAsync(card.Name, card.Id);
        isLoadingPrints = false;
        StateHasChanged();
    }

    private void GoBack()
    {
        if (!string.IsNullOrEmpty(ReturnQuery))
        {
            var q = Uri.EscapeDataString(ReturnQuery);
            Navigation.NavigateTo($"/simplesearch?Query={q}&Page={ReturnPage}");
        }
        else
        {
            Navigation.NavigateTo("/simplesearch");
        }
    }

    private void ToggleCardFace() => showBackFace = !showBackFace;

    private string GetCardImage(ScryfallCard c)
    {
        static string Best(ScryfallImageUris? uris) =>
            !string.IsNullOrEmpty(uris?.Large) ? uris.Large : uris?.Normal ?? string.Empty;

        if (IsDoubleFacedCard(c) && c.CardFaces.Count > 0)
            return Best(showBackFace && c.CardFaces.Count > 1 ? c.CardFaces[1].ImageUris : c.CardFaces[0].ImageUris);

        return Best(c.ImageUris);
    }

    private bool IsDoubleFacedCard(ScryfallCard c) =>
        c.Layout == "transform" || c.Layout == "modal_dfc" || c.CardFaces?.Count > 1;

    private static string FormatPrice(string? val, string symbol) =>
        string.IsNullOrWhiteSpace(val) ? "—" : $"{symbol}{val}";

    private string GetRarityDisplay(string? rarity) => rarity?.ToLower() switch
    {
        "common"   => "Common",
        "uncommon" => "Uncommon",
        "rare"     => "Rare",
        "mythic"   => "Mythic Rare",
        _          => rarity ?? "Unknown"
    };

    private static string GetSourceLabel(string? source) => source switch
    {
        "wotc" => "Wizards of the Coast",
        "scryfall" => "Scryfall",
        _ => source ?? "Unknown"
    };

    private void NavigateToCard(string id)
    {
        if (!string.IsNullOrEmpty(ReturnQuery))
            Navigation.NavigateTo($"/card/{id}?returnQuery={Uri.EscapeDataString(ReturnQuery)}&returnPage={ReturnPage}");
        else
            Navigation.NavigateTo("/card/" + id);
    }

    private void SelectPrint(ScryfallCard print)
    {
        selectedPrintId = print.Id;
        selectedPrintImageUrl = print.ImageUris?.Large
            ?? print.ImageUris?.Normal
            ?? print.CardFaces?.FirstOrDefault()?.ImageUris?.Large
            ?? print.CardFaces?.FirstOrDefault()?.ImageUris?.Normal;
    }

    private void ResetPreview()
    {
        selectedPrintId = null;
        selectedPrintImageUrl = null;
    }

    // ── Add to Collection form ─────────────────────────────────────────────
    private bool   showCollectionForm = false;
    private string addCondition       = "NM";
    private int    addQuantity        = 1;
    private bool   addIsFoil          = false;

    private void ToggleCollectionForm()
    {
        showCollectionForm = !showCollectionForm;
        if (showCollectionForm)
        {
            addCondition = "NM";
            addQuantity  = 1;
            addIsFoil    = false;
        }
    }

    private void IncrementAddQty() => addQuantity++;
    private void DecrementAddQty() { if (addQuantity > 1) addQuantity--; }

    private void ConfirmAddToCollection()
    {
        showCollectionForm = false;
        var foilLabel = addIsFoil ? " (Foil)" : "";
        ToastService.Show($"Added {addQuantity}× {card?.Name}{foilLabel} [{addCondition}] to collection!");
    }

    private void AddToDeck()  => ToastService.Show($"Deck builder coming soon!");
    private void ShareCard()  => JS.InvokeVoidAsync("navigator.clipboard.writeText", Navigation.Uri);
}
