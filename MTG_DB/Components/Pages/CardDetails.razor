@page "/card/{id}"
@using MTG_DB.Models
@using MtgInventoryApp.Models
@using MtgInventoryApp.Services
@inject MtgInventoryApp.Services.ScryfallService Scryfall
@inject ToastService ToastService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>MTGHUB - @(card?.Name ?? "Card Details")</PageTitle>

<div class="card-details-page">
    <!-- Header -->
    <header class="details-header">
        <div class="header-content">
            <h1 class="logo" @onclick='() => Navigation.NavigateTo("/")'>MTGHUB</h1>
            <button class="back-btn" @onclick="GoBack">
                ← Back to Search
            </button>
        </div>
    </header>

    <!-- Main Content -->
    <main class="details-main">
        @if (isLoading)
        {
            <div class="card-details-container">
                <!-- Skeleton: image column -->
                <div class="card-image-section">
                    <div class="image-container">
                        <div class="skeleton-image-large"></div>
                    </div>
                </div>
                <!-- Skeleton: info column -->
                <div class="card-info-section">
                    <div class="card-header">
                        <div class="skeleton-line skeleton-title"></div>
                        <div class="skeleton-line skeleton-badge"></div>
                    </div>
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="info-group">
                            <div class="skeleton-line skeleton-group-label"></div>
                            <div class="skeleton-grid-2">
                                <div class="skeleton-line"></div>
                                <div class="skeleton-line"></div>
                                <div class="skeleton-line skeleton-line-short"></div>
                                <div class="skeleton-line skeleton-line-short"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        else if (hasError)
        {
            <div class="error-state-details">
                <div class="error-icon-large">⚠️</div>
                <h2>Failed to Load Card</h2>
                <p>@errorMessage</p>
                <div class="error-actions">
                    <button class="action-btn primary" @onclick="LoadCardData">Retry</button>
                    <button class="back-btn" @onclick="GoBack">← Back to Search</button>
                </div>
            </div>
        }
        else if (card != null)
        {
            <div class="card-details-container">
                <!-- Left Column - Card Image -->
                <div class="card-image-section">
                    <div class="image-container">
                        @{
                            var cardImageUrl = GetCardImage(card);
                        }
                        @if (!string.IsNullOrEmpty(cardImageUrl))
                        {
                            <img src="@cardImageUrl"
                                 class="main-card-image"
                                 alt="@card.Name"
                                 @onclick='() => JS.InvokeVoidAsync("window.open", cardImageUrl, "_blank")' />
                            <div class="image-size-note">Click to view full size</div>
                        }
                        else
                        {
                            <div class="no-image-large">
                                <span>🃏</span>
                                <p>No image available</p>
                            </div>
                        }

                        @if (IsDoubleFacedCard(card))
                        {
                            <div class="dfc-controls">
                                <button class="dfc-btn @(showBackFace ? "active" : "")"
                                        @onclick="ToggleCardFace">
                                    @if (showBackFace)
                                    {
                                        <span>Show Front</span>
                                    }
                                    else
                                    {
                                        <span>Show Back</span>
                                    }
                                </button>
                            </div>
                        }
                    </div>
                </div>

                <!-- Right Column - Card Details -->
                <div class="card-info-section">
                    <div class="card-header">
                        <h1 class="card-title">@card.Name</h1>
                        <div class="card-set-badge">
                            <span class="set-name">@card.SetName</span>
                            <span class="set-code">@card.Set.ToUpper()</span>
                        </div>
                    </div>

                    <!-- Basic Info -->
                    <div class="info-group">
                        <h3>Card Details</h3>
                        <div class="info-grid">
                            <div class="info-item">
                                <span class="label">Mana Cost</span>
                                <span class="value">@(card.ManaCost ?? "—")</span>
                            </div>
                            <div class="info-item">
                                <span class="label">Type</span>
                                <span class="value">@(card.TypeLine ?? "—")</span>
                            </div>
                            <div class="info-item">
                                <span class="label">Rarity</span>
                                <span class="value rarity @card.Rarity?.ToLower()">@GetRarityDisplay(card.Rarity)</span>
                            </div>
                            <div class="info-item">
                                <span class="label">Collector Number</span>
                                <span class="value">@(card.CollectorNumber ?? "—")</span>
                            </div>
                        </div>
                    </div>

                    <!-- Rules Text -->
                    <div class="info-group">
                        <h3>Rules Text</h3>
                        <div class="rules-text">
                            @if (!string.IsNullOrEmpty(card.OracleText))
                            {
                                @card.OracleText
                            }
                            else
                            {
                                <p class="text-muted">No rules text.</p>
                            }
                        </div>
                    </div>

                    <!-- Stats -->
                    <div class="info-group">
                        <h3>Stats</h3>
                        <div class="stats-grid">
                            <div class="stat-item">
                                <span class="stat-label">Power</span>
                                <span class="stat-value">@(GetPower(card) ?? "—")</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-label">Toughness</span>
                                <span class="stat-value">@(GetToughness(card) ?? "—")</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-label">Loyalty</span>
                                <span class="stat-value">@(GetLoyalty(card) ?? "—")</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-label">CMC</span>
                                <span class="stat-value">@(GetCmc(card) ?? "—")</span>
                            </div>
                        </div>
                    </div>

                    <!-- Pricing -->
                    <div class="info-group">
                        <h3>Pricing</h3>
                        <div class="pricing-grid">
                            <div class="price-item">
                                <span class="price-label">Regular</span>
                                <span class="price-value">@FormatUsd(card.Prices?.Usd)</span>
                            </div>
                            <div class="price-item">
                                <span class="price-label">Foil</span>
                                <span class="price-value">@FormatUsd(card.Prices?.UsdFoil)</span>
                            </div>
                            <div class="price-item">
                                <span class="price-label">Etched</span>
                                <span class="price-value">@FormatUsd(card.Prices?.UsdEtched)</span>
                            </div>
                            <div class="price-item">
                                <span class="price-label">MTGO</span>
                                <span class="price-value">@FormatUsd(card.Prices?.Tix)</span>
                            </div>
                        </div>
                    </div>

                    <!-- Additional Info -->
                    <div class="info-group">
                        <h3>Additional Information</h3>
                        <div class="additional-info">
                            <div class="info-row">
                                <span class="info-label">Artist</span>
                                <span class="info-value">@(GetArtist(card) ?? "—")</span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Border</span>
                                <span class="info-value">@(GetBorderColor(card) ?? "—")</span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Frame</span>
                                <span class="info-value">@(GetFrame(card) ?? "—")</span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Language</span>
                                <span class="info-value">@(GetLanguage(card) ?? "—")</span>
                            </div>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="actions-section">
                        <button class="action-btn primary" @onclick="AddToCollection">
                            + Add to Collection
                        </button>
                        <button class="action-btn secondary" @onclick="AddToDeck">
                            + Add to Deck
                        </button>
                        <button class="action-btn tertiary" @onclick="ShareCard">
                            📤 Share
                        </button>
                    </div>
                </div>
            </div>
        }
    </main>
</div>

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    [Parameter]
    [SupplyParameterFromQuery]
    public string? ReturnQuery { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public int ReturnPage { get; set; } = 1;

    private ScryfallCard? card;
    private bool isLoading = true;
    private bool hasError;
    private string? errorMessage;
    private bool showBackFace = false;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(Id))
        {
            await LoadCardData();
        }
        else
        {
            isLoading = false;
        }
    }

    private async Task LoadCardData()
    {
        isLoading = true;
        hasError = false;
        errorMessage = null;
        card = null;
        StateHasChanged();

        try
        {
            card = await Scryfall.GetCardByIdAsync(Id);
            if (card == null)
            {
                hasError = true;
                errorMessage = "Card not found.";
                ToastService.Show("Card not found.");
            }
        }
        catch (HttpRequestException)
        {
            hasError = true;
            errorMessage = "Network error — check your connection and try again.";
            ToastService.Show(errorMessage);
        }
        catch (Exception ex)
        {
            hasError = true;
            errorMessage = $"Failed to load card: {ex.Message}";
            ToastService.Show(errorMessage);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void GoBack()
    {
        if (!string.IsNullOrEmpty(ReturnQuery))
        {
            var q = Uri.EscapeDataString(ReturnQuery);
            Navigation.NavigateTo($"/simplesearch?Query={q}&Page={ReturnPage}");
        }
        else
        {
            Navigation.NavigateTo("/simplesearch");
        }
    }

    private void ToggleCardFace()
    {
        showBackFace = !showBackFace;
    }

    private string GetCardImage(ScryfallCard card)
    {
        string GetImageUrl(ScryfallImageUris uris)
        {
            return !string.IsNullOrEmpty(uris?.Large) ? uris.Large : uris?.Normal ?? string.Empty;
        }

        if (IsDoubleFacedCard(card) && showBackFace && card.CardFaces.Count > 1)
        {
            return GetImageUrl(card.CardFaces[1].ImageUris);
        }
        else if (IsDoubleFacedCard(card) && card.CardFaces.Count > 0)
        {
            return GetImageUrl(card.CardFaces[0].ImageUris);
        }
        return GetImageUrl(card.ImageUris);
    }

    private bool IsDoubleFacedCard(ScryfallCard card)
    {
        return card.Layout == "transform" || card.Layout == "modal_dfc" || card.CardFaces?.Count > 1;
    }

    private string? GetPower(ScryfallCard card) => card.Power;
    private string? GetToughness(ScryfallCard card) => card.Toughness;
    private string? GetLoyalty(ScryfallCard card) => card.Loyalty;
    private string? GetCmc(ScryfallCard card) => card.Cmc > 0 ? card.Cmc.ToString("G") : null;
    private string? GetArtist(ScryfallCard card) => card.Artist;
    private string? GetBorderColor(ScryfallCard card) => card.BorderColor;
    private string? GetFrame(ScryfallCard card) => card.Frame;
    private string? GetLanguage(ScryfallCard card) => card.Lang;

    private static string FormatUsd(string? usd) =>
        string.IsNullOrWhiteSpace(usd) ? "—" : $"${usd}";

    private string GetRarityDisplay(string? rarity) => rarity?.ToLower() switch
    {
        "common" => "Common",
        "uncommon" => "Uncommon",
        "rare" => "Rare",
        "mythic" => "Mythic Rare",
        _ => rarity ?? "Unknown"
    };

    private void AddToCollection()
    {
        JS.InvokeVoidAsync("alert", $"Added {card?.Name} to collection!");
    }

    private void AddToDeck()
    {
        JS.InvokeVoidAsync("alert", $"Added {card?.Name} to deck!");
    }

    private void ShareCard()
    {
        JS.InvokeVoidAsync("alert", $"Share link for {card?.Name} copied!");
    }
}
