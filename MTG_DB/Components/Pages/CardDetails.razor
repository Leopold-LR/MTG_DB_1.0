@page "/card/{id}"
@using MTG_DB.Models
@using MtgInventoryApp.Models
@inject MtgInventoryApp.Services.ScryfallService Scryfall
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>MTGHUB - @card?.Name</PageTitle>

<div class="card-details-page">
    <!-- Header -->
    <header class="details-header">
        <div class="header-content">
            <h1 class="logo" @onclick='() => Navigation.NavigateTo("/")'>MTGHUB</h1>
            <button class="back-btn" @onclick="GoBack">
                ← Back to Search
            </button>
        </div>
    </header>

    <!-- Main Content -->
    <main class="details-main">
        @if (card == null)
        {
            <div class="loading">
                <div class="spinner"></div>
                <p>Loading card details...</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-state">
                <div class="error-icon">⚠️</div>
                <h3>Error Loading Card</h3>
                <p>@errorMessage</p>
                <button class="action-btn" @onclick="GoBack">Go Back</button>
            </div>
        }
        else
        {
            <div class="card-details-container">
                <!-- Left Column - Card Image -->
                <div class="card-image-section">
                    <div class="image-container">
                        @{
                            var cardImageUrl = GetCardImage(card);
                        }
                        @if (!string.IsNullOrEmpty(cardImageUrl))
                        {
                            <img src="@cardImageUrl"
                                 class="main-card-image"
                                 alt="@card.Name"
                                 @onclick='() => JS.InvokeVoidAsync("window.open", cardImageUrl, "_blank")' />
                            <div class="image-size-note">Click to view full size</div>
                        }
                        else
                        {
                            <div class="no-image-large">
                                <span>🃏</span>
                                <p>No image available</p>
                            </div>
                        }

                        @if (IsDoubleFacedCard(card))
                        {
                            <div class="dfc-controls">
                                <button class="dfc-btn @(showBackFace ? "active" : "")"
                                        @onclick="ToggleCardFace">
                                    @if (showBackFace)
                                    {
                                        <span>Show Front</span>
                                    }
                                    else
                                    {
                                        <span>Show Back</span>
                                    }
                                </button>
                            </div>
                        }
                    </div>
                </div>

                <!-- Right Column - Card Details -->
                <div class="card-info-section">
                    <div class="card-header">
                        <h1 class="card-title">@GetDisplayName(card)</h1>
                        <div class="card-set-badge">
                            <span class="set-name">@card.SetName</span>
                            <span class="set-code">@card.Set.ToUpper()</span>
                        </div>
                    </div>

                    <!-- Basic Info -->
                    <div class="info-group">
                        <h3>Card Details</h3>
                        <div class="info-grid">
                            <div class="info-item">
                                <span class="label">Mana Cost</span>
                                <span class="value">@GetManaCost(card)</span>
                            </div>
                            <div class="info-item">
                                <span class="label">Type</span>
                                <span class="value">@GetTypeLine(card)</span>
                            </div>
                            <div class="info-item">
                                <span class="label">Rarity</span>
                                <span class="value rarity @card.Rarity?.ToLower()">@GetRarityDisplay(card.Rarity)</span>
                            </div>
                            <div class="info-item">
                                <span class="label">Collector Number</span>
                                <span class="value">@card.CollectorNumber</span>
                            </div>
                        </div>
                    </div>

                    <!-- Rules Text -->
                    <div class="info-group">
                        <h3>Rules Text</h3>
                        <div class="rules-text">
                            @if (!string.IsNullOrEmpty(GetOracleText(card)))
                            {
                                var oracleText = GetOracleText(card);
                                if (!string.IsNullOrEmpty(oracleText))
                                {
                                    @foreach (var line in oracleText.Split('\n'))
                                    {
                                        if (!string.IsNullOrWhiteSpace(line))
                                        {
                                            <p>@line</p>
                                        }
                                    }
                                }
                            }
                            else
                            {
                                <p class="text-muted">No rules text</p>
                            }
                        </div>
                    </div>

                    <!-- Stats -->
                    <div class="info-group">
                        <h3>Stats</h3>
                        <div class="stats-grid">
                            <div class="stat-item">
                                <span class="stat-label">Power</span>
                                <span class="stat-value">@GetPower(card)</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-label">Toughness</span>
                                <span class="stat-value">@GetToughness(card)</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-label">Loyalty</span>
                                <span class="stat-value">@GetLoyalty(card)</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-label">CMC</span>
                                <span class="stat-value">@GetCmc(card)</span>
                            </div>
                        </div>
                    </div>

                    <!-- Pricing -->
                    <div class="info-group">
                        <h3>Pricing</h3>
                        <div class="pricing-grid">
                            <div class="price-item">
                                <span class="price-label">Regular</span>
                                <span class="price-value">@FormatUsd(card.Prices?.Usd)</span>
                            </div>
                            <div class="price-item">
                                <span class="price-label">Foil</span>
                                <span class="price-value">@FormatUsd(card.Prices?.UsdFoil)</span>
                            </div>
                            <div class="price-item">
                                <span class="price-label">Etched</span>
                                <span class="price-value">@FormatUsd(card.Prices?.UsdEtched)</span>
                            </div>
                            <div class="price-item">
                                <span class="price-label">MTGO</span>
                                <span class="price-value">@FormatUsd(card.Prices?.Tix)</span>
                            </div>
                        </div>
                    </div>

                    <!-- Additional Info -->
                    <div class="info-group">
                        <h3>Additional Information</h3>
                        <div class="additional-info">
                            <div class="info-row">
                                <span class="info-label">Artist</span>
                                <span class="info-value">@GetArtist(card)</span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Border</span>
                                <span class="info-value">@GetBorderColor(card)</span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Frame</span>
                                <span class="info-value">@GetFrame(card)</span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Language</span>
                                <span class="info-value">@GetLanguage(card)</span>
                            </div>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="actions-section">
                        <button class="action-btn primary" @onclick="AddToCollection">
                            + Add to Collection
                        </button>
                        <button class="action-btn secondary" @onclick="AddToDeck">
                            + Add to Deck
                        </button>
                        <button class="action-btn tertiary" @onclick="ShareCard">
                            📤 Share
                        </button>
                    </div>
                </div>
            </div>
        }
    </main>
</div>

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private ScryfallCard? card;
    private bool showBackFace = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(Id))
        {
            await LoadCardData();
        }
    }

    private async Task LoadCardData()
    {
        try
        {
            card = await Scryfall.GetCardByIdAsync(Id);

            if (card == null)
            {
                errorMessage = "Card not found. It may have been removed or the ID is invalid.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading card: {ex.Message}";
            card = null;
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/simplesearch");
    }

    private void ToggleCardFace()
    {
        showBackFace = !showBackFace;
    }

    private string GetDisplayName(ScryfallCard card)
    {
        if (IsDoubleFacedCard(card) && card.CardFaces.Any())
        {
            var currentFace = showBackFace && card.CardFaces.Count > 1
                ? card.CardFaces[1]
                : card.CardFaces[0];
            return currentFace.Name;
        }
        return card.Name;
    }

    private string GetCardImage(ScryfallCard card)
    {
        if (IsDoubleFacedCard(card))
        {
            // For DFCs, get the appropriate face
            var face = showBackFace && card.CardFaces.Count > 1
                ? card.CardFaces[1]
                : card.CardFaces.FirstOrDefault();

            // Try to get image from the face
            var faceImage = face?.ImageUris?.Large ?? face?.ImageUris?.Normal;
            if (!string.IsNullOrEmpty(faceImage))
                return faceImage;
        }

        // For regular cards or fallback
        return card.ImageUris?.Large ?? card.ImageUris?.Normal ?? string.Empty;
    }

    private bool IsDoubleFacedCard(ScryfallCard card)
    {
        return card.Layout == "transform" ||
               card.Layout == "modal_dfc" ||
               card.Layout == "double_faced_token" ||
               card.CardFaces?.Count > 1;
    }

    // Helper methods to get data from the correct source
    private string GetManaCost(ScryfallCard card)
    {
        if (IsDoubleFacedCard(card) && card.CardFaces.Any())
        {
            var currentFace = showBackFace && card.CardFaces.Count > 1
                ? card.CardFaces[1]
                : card.CardFaces[0];
            return !string.IsNullOrEmpty(currentFace.ManaCost) ? currentFace.ManaCost : "—";
        }
        return !string.IsNullOrEmpty(card.ManaCost) ? card.ManaCost : "—";
    }

    private string GetTypeLine(ScryfallCard card)
    {
        if (IsDoubleFacedCard(card) && card.CardFaces.Any())
        {
            var currentFace = showBackFace && card.CardFaces.Count > 1
                ? card.CardFaces[1]
                : card.CardFaces[0];
            return !string.IsNullOrEmpty(currentFace.TypeLine) ? currentFace.TypeLine : "—";
        }
        return !string.IsNullOrEmpty(card.TypeLine) ? card.TypeLine : "—";
    }

    private string GetOracleText(ScryfallCard card)
    {
        if (IsDoubleFacedCard(card) && card.CardFaces.Any())
        {
            var currentFace = showBackFace && card.CardFaces.Count > 1
                ? card.CardFaces[1]
                : card.CardFaces[0];
            return !string.IsNullOrEmpty(currentFace.OracleText) ? currentFace.OracleText : card.OracleText;
        }
        return card.OracleText ?? string.Empty;
    }

    private string GetPower(ScryfallCard card)
    {
        if (IsDoubleFacedCard(card) && card.CardFaces.Any())
        {
            var currentFace = showBackFace && card.CardFaces.Count > 1
                ? card.CardFaces[1]
                : card.CardFaces[0];
            return !string.IsNullOrEmpty(currentFace.Power) ? currentFace.Power : card.Power ?? "—";
        }
        return !string.IsNullOrEmpty(card.Power) ? card.Power : "—";
    }

    private string GetToughness(ScryfallCard card)
    {
        if (IsDoubleFacedCard(card) && card.CardFaces.Any())
        {
            var currentFace = showBackFace && card.CardFaces.Count > 1
                ? card.CardFaces[1]
                : card.CardFaces[0];
            return !string.IsNullOrEmpty(currentFace.Toughness) ? currentFace.Toughness : card.Toughness ?? "—";
        }
        return !string.IsNullOrEmpty(card.Toughness) ? card.Toughness : "—";
    }

    private string GetLoyalty(ScryfallCard card)
    {
        if (IsDoubleFacedCard(card) && card.CardFaces.Any())
        {
            var currentFace = showBackFace && card.CardFaces.Count > 1
                ? card.CardFaces[1]
                : card.CardFaces[0];
            return !string.IsNullOrEmpty(currentFace.Loyalty) ? currentFace.Loyalty : card.Loyalty ?? "—";
        }
        return !string.IsNullOrEmpty(card.Loyalty) ? card.Loyalty : "—";
    }

    private string GetCmc(ScryfallCard card)
    {
        return card.ConvertedManaCost > 0 ? card.ConvertedManaCost.ToString() : "—";
    }

    private string GetArtist(ScryfallCard card)
    {
        if (IsDoubleFacedCard(card) && card.CardFaces.Any())
        {
            var currentFace = showBackFace && card.CardFaces.Count > 1
                ? card.CardFaces[1]
                : card.CardFaces[0];
            return !string.IsNullOrEmpty(currentFace.Artist) ? currentFace.Artist : card.Artist ?? "—";
        }
        return !string.IsNullOrEmpty(card.Artist) ? card.Artist : "—";
    }

    private string GetBorderColor(ScryfallCard card)
    {
        return !string.IsNullOrEmpty(card.BorderColor) ? card.BorderColor : "—";
    }

    private string GetFrame(ScryfallCard card)
    {
        return !string.IsNullOrEmpty(card.Frame) ? card.Frame : "—";
    }

    private string GetLanguage(ScryfallCard card)
    {
        return !string.IsNullOrEmpty(card.Lang) ? card.Lang : "—";
    }

    private static string FormatUsd(string? usd) =>
        string.IsNullOrWhiteSpace(usd) ? "—" : $"${usd}";

    private string GetRarityDisplay(string? rarity) => rarity?.ToLower() switch
    {
        "common" => "Common",
        "uncommon" => "Uncommon",
        "rare" => "Rare",
        "mythic" => "Mythic Rare",
        _ => rarity ?? "Unknown"
    };

    private void AddToCollection()
    {
        JS.InvokeVoidAsync("alert", $"Added {card?.Name} to collection!");
    }

    private void AddToDeck()
    {
        JS.InvokeVoidAsync("alert", $"Added {card?.Name} to deck!");
    }

    private void ShareCard()
    {
        var cardUrl = $"{Navigation.BaseUri}card/{card?.Id}";
        JS.InvokeVoidAsync("navigator.clipboard.writeText", cardUrl);
        JS.InvokeVoidAsync("alert", $"Link copied to clipboard!");
    }
}